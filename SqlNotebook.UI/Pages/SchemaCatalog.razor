@using System.Net.Http.Json
@using DAP.SqlNotebook.Contract.Entities
@using DAP.SqlNotebook.UI.Components
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor

@page "/schema-catalog"

<PageTitle>Schema catalog</PageTitle>

<MudPaper Class="pa-4" Elevation="0">
    <MudStack Spacing="3">
        <MudText Typo="Typo.h6">Schema catalog</MudText>
        <MudStack Row Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddDialog">Add source</MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadSources">Refresh</MudButton>
            <MudButton Variant="Variant.Outlined" Href="@("/schema-catalog/entities")">Entities &amp; fields</MudButton>
        </MudStack>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else
        {
            <MudSimpleTable Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm">
                <thead>
                    <tr>
                        <th>Status</th>
                        <th>Name</th>
                        <th>Owner</th>
                        <th>Provider</th>
                        <th>Database</th>
                        <th>Auth / Login</th>
                        <th>Description</th>
                        <th style="width:180px">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _sources)
                    {
                        var status = _statusMap.GetValueOrDefault(item.Id);
                        <tr>
                            <td>
                                @if (status != null)
                                {
                                    @if (status.Status == ConnectionStatusInfo.Ok)
                                    {
                                        <MudTooltip Text="@(status.Message ?? "Available")">
                                            <MudIcon Icon="@Icons.Material.Filled.Circle" Color="Color.Success" Style="font-size: 1rem;" />
                                        </MudTooltip>
                                    }
                                    else if (status.Status == ConnectionStatusInfo.Failed)
                                    {
                                        <MudTooltip Text="@(status.Message ?? "Unavailable")">
                                            <MudIcon Icon="@Icons.Material.Filled.Circle" Color="Color.Error" Style="font-size: 1rem;" />
                                        </MudTooltip>
                                    }
                                    else
                                    {
                                        <MudTooltip Text="@(status.Message ?? "Unknown")">
                                            <MudIcon Icon="@Icons.Material.Filled.Circle" Color="Color.Default" Style="font-size: 1rem;" />
                                        </MudTooltip>
                                    }
                                }
                                else if (_checkingIds.Contains(item.Id) || _loadingStatusIds.Contains(item.Id))
                                {
                                    <MudTooltip Text="@(_checkingIds.Contains(item.Id) ? "Checking..." : "Loading...")">
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Style="width:20px; height:20px;" />
                                    </MudTooltip>
                                }
                                else
                                {
                                    <MudTooltip Text="Click check to verify availability">
                                        <MudIcon Icon="@Icons.Material.Filled.Circle" Color="Color.Inherit" Style="font-size: 1rem; opacity: 0.4;" />
                                    </MudTooltip>
                                }
                                <MudTooltip Text="Check availability">
                                    <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" OnClick="@(() => CheckStatus(item))" />
                                </MudTooltip>
                            </td>
                            <td>@item.Name</td>
                            <td>@(item.Owner ?? "—")</td>
                            <td>@(item.Provider ?? "—")</td>
                            <td>@(item.DatabaseName ?? "—")</td>
                            <td>@(item.AuthType ?? "—")@(string.Equals(item.AuthType, "Basic", StringComparison.OrdinalIgnoreCase) && !string.IsNullOrEmpty(item.Login) ? " / " + item.Login : "")</td>
                            <td>
                                @if (_editingDescriptionId == item.Id)
                                {
                                    <MudTextField @bind-Value="_editDescriptionValue" Variant="Variant.Outlined" Dense="true" Style="max-width: 200px;" @onkeydown="OnDescriptionKeyDown" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Check" Size="Size.Small" OnClick="@(() => SaveSourceDescription(item))" Title="Save" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="CancelEditDescription" Title="Cancel" />
                                }
                                else
                                {
                                    <span>@(item.Description ?? "—")</span>
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => StartEditDescription(item))" Title="Edit description" />
                                }
                            </td>
                            <td>
                                <MudTooltip Text="Import DB structure">
                                    <MudIconButton Icon="@Icons.Material.Filled.Download" Size="Size.Small" OnClick="@(() => ImportStructure(item))" />
                                </MudTooltip>
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditDialog(item))" title="Edit" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" OnClick="@(() => ConfirmDelete(item))" title="Delete" />
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
            @if (_sources.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">No sources. Add a source to connect to MSSQL, ClickHouse, or Kafka.</MudText>
            }
        }
    </MudStack>
</MudPaper>

<MudDialog @bind-Visible="_showEditDialog" Options="@(new DialogOptions { CloseOnEscapeKey = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editingId.HasValue ? "Edit source" : "New source")</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2" @onkeydown="OnEditDialogKeyDown">
            <MudTextField @bind-Value="_editName" Label="Name" Variant="Variant.Outlined" Required />
            <MudTextField @bind-Value="_editOwner" Label="Owner" Variant="Variant.Outlined" />
            <MudSelect T="string?" @bind-Value="_editProvider" Label="Provider" Variant="Variant.Outlined">
                <MudSelectItem T="string?" Value="@("MSSQL")">MSSQL</MudSelectItem>
                <MudSelectItem T="string?" Value="@("ClickHouse")">ClickHouse</MudSelectItem>
                <MudSelectItem T="string?" Value="@("Kafka")">Kafka</MudSelectItem>
            </MudSelect>
            <MudTextField @bind-Value="_editConnectionInfo" Label="@(_editProvider == "Kafka" ? "Bootstrap servers (host:port)" : "Connection (server or connection string)")" Variant="Variant.Outlined" Lines="2" />
            <MudTextField @bind-Value="_editDatabaseName" Label="Database name" Variant="Variant.Outlined" Placeholder="e.g. master, MyDb" />
            <MudSelect T="string?" @bind-Value="_editAuthType" Label="Authentication" Variant="Variant.Outlined">
                <MudSelectItem T="string?" Value="@("Kerberos")">Kerberos (Windows)</MudSelectItem>
                <MudSelectItem T="string?" Value="@("Basic")">Basic (login / password)</MudSelectItem>
            </MudSelect>
            @if (string.Equals(_editAuthType, "Basic", StringComparison.OrdinalIgnoreCase))
            {
                <MudTextField @bind-Value="_editLogin" Label="Login" Variant="Variant.Outlined" />
                <MudTextField @bind-Value="_editPassword" Label="Password" Variant="Variant.Outlined" InputType="InputType.Password" Placeholder="@(_editingId.HasValue ? "Leave empty to keep current" : "")" />
            }
            @if (string.Equals(_editProvider, "Kafka", StringComparison.OrdinalIgnoreCase))
            {
                <MudTextField @bind-Value="_editKafkaConsumerGroupPrefix"
                              Label="Consumer group prefix"
                              Variant="Variant.Outlined"
                              Placeholder="e.g. sqlnotebook-peek"
                              HelperText="Used as groupId when Auto-generate is off; otherwise GUID is appended each request." />
                <MudCheckBox T="bool" @bind-Checked="_editKafkaConsumerGroupAutoGenerate"
                             Label="Auto-generate (append GUID each time)"
                             Color="Color.Primary" />
            }
            <MudTextField @bind-Value="_editDescription" Label="Description" Variant="Variant.Outlined" Lines="2" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseEditDialog">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveSource" Disabled="@string.IsNullOrWhiteSpace(_editName)">Save</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_showDeleteConfirm" Options="@(new DialogOptions { CloseOnEscapeKey = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">Delete source</MudText>
    </TitleContent>
    <DialogContent>
        <MudText>Delete source "@_deleteName"? This cannot be undone.</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDeleteConfirm">Cancel</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="DeleteSource">Delete</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Inject] private HttpClient Http { get; set; } = null!;
    [Inject] private ISnackbar Snackbar { get; set; } = null!;
    [Inject] private ICatalogRefreshService CatalogRefresh { get; set; } = null!;

    private List<CatalogNodeInfo> _sources = new();
    private Dictionary<Guid, ConnectionHealthInfo> _statusMap = new();
    private bool _loading = true;
    private bool _showEditDialog;
    private bool _showDeleteConfirm;
    private Guid? _editingId;
    private string _editName = "";
    private string? _editOwner;
    private string? _editProvider = "MSSQL";
    private string? _editConnectionInfo;
    private string? _editDatabaseName;
    private string? _editAuthType = "Kerberos";
    private string? _editLogin;
    private string? _editPassword;
    private string? _editDescription;
    private string _editKafkaConsumerGroupPrefix = "sqlnotebook-peek";
    private bool _editKafkaConsumerGroupAutoGenerate = false;
    private Guid? _deleteId;
    private string _deleteName = "";
    private HashSet<Guid> _checkingIds = new();
    private HashSet<Guid> _loadingStatusIds = new();
    private Guid? _editingDescriptionId;
    private string? _editDescriptionValue;

    protected override async Task OnInitializedAsync()
    {
        await LoadSources();
    }

    private async Task LoadSources()
    {
        _loading = true;
        try
        {
            var nodes = await Http.GetFromJsonAsync<List<CatalogNodeInfo>>("api/v1/catalog/databases");
            _sources = nodes ?? new List<CatalogNodeInfo>();
            _statusMap = new Dictionary<Guid, ConnectionHealthInfo>();
        }
        finally
        {
            _loading = false;
        }
        await InvokeAsync(StateHasChanged);
        LoadStatusesInBackground();
    }

    private async void LoadStatusesInBackground()
    {
        if (_sources.Count == 0) return;
        foreach (var id in _sources.Select(s => s.Id))
            _loadingStatusIds.Add(id);
        await InvokeAsync(StateHasChanged);
        foreach (var s in _sources)
        {
            try
            {
                var status = await Http.GetFromJsonAsync<ConnectionHealthInfo>($"api/v1/catalog/nodes/{s.Id:N}/connection-status");
                await InvokeAsync(() =>
                {
                    _loadingStatusIds.Remove(s.Id);
                    if (status != null)
                        _statusMap[s.Id] = status;
                    StateHasChanged();
                });
            }
            catch
            {
                await InvokeAsync(() =>
                {
                    _loadingStatusIds.Remove(s.Id);
                    StateHasChanged();
                });
            }
        }
    }

    private void OpenAddDialog()
    {
        _editingId = null;
        _editName = "";
        _editOwner = null;
        _editProvider = "MSSQL";
        _editConnectionInfo = null;
        _editDatabaseName = null;
        _editAuthType = "Kerberos";
        _editLogin = null;
        _editPassword = null;
        _editDescription = null;
        _editKafkaConsumerGroupPrefix = "sqlnotebook-peek";
        _editKafkaConsumerGroupAutoGenerate = false;
        _showEditDialog = true;
    }

    private void OpenEditDialog(CatalogNodeInfo item)
    {
        _editingId = item.Id;
        _editName = item.Name;
        _editOwner = item.Owner;
        _editProvider = item.Provider ?? "MSSQL";
        _editConnectionInfo = item.ConnectionInfo;
        _editDatabaseName = item.DatabaseName;
        _editAuthType = item.AuthType ?? "Kerberos";
        _editLogin = item.Login;
        _editPassword = null; // never show stored password
        _editDescription = item.Description;
        _editKafkaConsumerGroupPrefix = string.IsNullOrWhiteSpace(item.ConsumerGroupPrefix) ? "sqlnotebook-peek" : item.ConsumerGroupPrefix!;
        _editKafkaConsumerGroupAutoGenerate = item.ConsumerGroupAutoGenerate;
        _showEditDialog = true;
    }

    private void CloseEditDialog()
    {
        _showEditDialog = false;
    }

    private async Task OnEditDialogKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_editName))
            await SaveSource();
    }

    private async Task SaveSource()
    {
        if (string.IsNullOrWhiteSpace(_editName)) return;
        try
        {
            if (_editingId.HasValue)
            {
                var update = new CatalogNodeUpdateInfo
                {
                    Name = _editName,
                    Owner = _editOwner,
                    Provider = _editProvider,
                    ConnectionInfo = _editConnectionInfo,
                    DatabaseName = _editDatabaseName,
                    AuthType = _editAuthType,
                    Login = _editLogin,
                    Password = _editPassword,
                    Description = _editDescription,
                    ConsumerGroupPrefix = string.Equals(_editProvider, "Kafka", StringComparison.OrdinalIgnoreCase) ? _editKafkaConsumerGroupPrefix : null,
                    ConsumerGroupAutoGenerate = string.Equals(_editProvider, "Kafka", StringComparison.OrdinalIgnoreCase) ? _editKafkaConsumerGroupAutoGenerate : null,
                };
                var res = await Http.PutAsJsonAsync($"api/v1/catalog/nodes/{_editingId.Value:N}", update);
                if (!res.IsSuccessStatusCode) return;
            }
            else
            {
                var create = new CatalogNodeCreateInfo
                {
                    ParentId = null,
                    Type = 1,
                    Name = _editName,
                    Owner = _editOwner,
                    Provider = _editProvider,
                    ConnectionInfo = _editConnectionInfo,
                    DatabaseName = _editDatabaseName,
                    AuthType = _editAuthType,
                    Login = _editLogin,
                    Password = _editPassword,
                    Description = _editDescription,
                    ConsumerGroupPrefix = string.Equals(_editProvider, "Kafka", StringComparison.OrdinalIgnoreCase) ? _editKafkaConsumerGroupPrefix : null,
                    ConsumerGroupAutoGenerate = string.Equals(_editProvider, "Kafka", StringComparison.OrdinalIgnoreCase) && _editKafkaConsumerGroupAutoGenerate,
                };
                await Http.PostAsJsonAsync("api/v1/catalog/nodes", create);
            }
            CloseEditDialog();
            await LoadSources();
            CatalogRefresh.NotifyRefresh();
        }
        catch { /* todo: snackbar */ }
    }

    private async Task CheckStatus(CatalogNodeInfo item)
    {
        if (_checkingIds.Contains(item.Id)) return;
        _checkingIds.Add(item.Id);
        try
        {
            StateHasChanged();
            try
            {
                var status = await Http.GetFromJsonAsync<ConnectionHealthInfo>($"api/v1/catalog/nodes/{item.Id:N}/connection-status");
                if (status != null)
                {
                    _statusMap[item.Id] = status;
                }
            }
            catch { /* ignore */ }
        }
        finally
        {
            _checkingIds.Remove(item.Id);
            StateHasChanged();
        }
    }

    private void ConfirmDelete(CatalogNodeInfo item)
    {
        _deleteId = item.Id;
        _deleteName = item.Name;
        _showDeleteConfirm = true;
    }

    private void CloseDeleteConfirm()
    {
        _showDeleteConfirm = false;
        _deleteId = null;
        _deleteName = "";
    }

    private async Task DeleteSource()
    {
        if (!_deleteId.HasValue) return;
        try
        {
            var res = await Http.DeleteAsync($"api/v1/catalog/nodes/{_deleteId.Value:N}");
            if (res.IsSuccessStatusCode)
            {
                CloseDeleteConfirm();
                await LoadSources();
                Snackbar.Add("Source deleted.", Severity.Success);
                CatalogRefresh.NotifyRefresh();
            }
            else
            {
                Snackbar.Add("Delete failed. The source may have child nodes or the server returned an error.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task ImportStructure(CatalogNodeInfo item)
    {
        try
        {
            var res = await Http.PostAsync($"api/v1/catalog/nodes/{item.Id:N}/import-structure", null);
            if (res.IsSuccessStatusCode)
            {
                var result = await res.Content.ReadFromJsonAsync<SchemaImportResultInfo>();
                if (result != null)
                {
                    Snackbar.Add($"Imported {result.TablesCount} tables, {result.FieldsCount} columns.", Severity.Success);
                    await LoadSources();
                }
            }
            else
            {
                var result = await res.Content.ReadFromJsonAsync<SchemaImportResultInfo>();
                Snackbar.Add(result?.Error ?? "Import failed.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Import failed: {ex.Message}", Severity.Error);
        }
    }

    private void StartEditDescription(CatalogNodeInfo item)
    {
        _editingDescriptionId = item.Id;
        _editDescriptionValue = item.Description ?? "";
    }

    private void CancelEditDescription()
    {
        _editingDescriptionId = null;
        _editDescriptionValue = null;
    }

    private async Task OnDescriptionKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            var item = _sources.FirstOrDefault(s => s.Id == _editingDescriptionId);
            if (item != null) await SaveSourceDescription(item);
        }
        if (e.Key == "Escape")
            CancelEditDescription();
    }

    private async Task SaveSourceDescription(CatalogNodeInfo item)
    {
        if (_editingDescriptionId != item.Id) return;
        try
        {
            var update = new CatalogNodeUpdateInfo
            {
                Name = item.Name,
                Owner = item.Owner,
                Provider = item.Provider,
                ConnectionInfo = item.ConnectionInfo,
                DatabaseName = item.DatabaseName,
                AuthType = item.AuthType,
                Login = item.Login,
                Description = _editDescriptionValue,
                ConsumerGroupPrefix = item.ConsumerGroupPrefix,
                ConsumerGroupAutoGenerate = item.ConsumerGroupAutoGenerate,
            };
            var res = await Http.PutAsJsonAsync($"api/v1/catalog/nodes/{item.Id:N}", update);
            if (res.IsSuccessStatusCode)
            {
                item.Description = _editDescriptionValue;
                Snackbar.Add("Description saved.", Severity.Success);
            }
        }
        catch { Snackbar.Add("Failed to save description.", Severity.Error); }
        finally
        {
            CancelEditDescription();
            await InvokeAsync(StateHasChanged);
        }
    }
}
