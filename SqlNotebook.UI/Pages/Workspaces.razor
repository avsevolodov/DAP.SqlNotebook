@page "/workspaces"
@using System.Threading
@using DAP.SqlNotebook.Contract.Entities
@using DAP.SqlNotebook.Service.Client.V1
@using DAP.SqlNotebook.Service.Client.Exceptions
@using DAP.SqlNotebook.UI.Helpers
@using global::MudBlazor
@using SnackbarExtensions = DAP.SqlNotebook.UI.Helpers.SnackbarExtensions
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@inject IWorkspaceManager WorkspaceManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Workspaces</PageTitle>

<MudPaper Class="pa-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Spacing="2" Wrap="Wrap.Wrap">
        <MudText Typo="Typo.h5">Workspace</MudText>
        <MudTextField T="string" @bind-Value="_workspaceSearch" Placeholder="Search…" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Clearable="true" Style="max-width: 240px;" Immediate="true" />
        <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
            <MudButton Color="@(_workspaceViewMode == WorkspaceViewMode.Cards ? Color.Primary : Color.Default)" OnClick="@(() => _workspaceViewMode = WorkspaceViewMode.Cards)" StartIcon="@Icons.Material.Filled.ViewModule" title="Cards">Cards</MudButton>
            <MudButton Color="@(_workspaceViewMode == WorkspaceViewMode.Grid ? Color.Primary : Color.Default)" OnClick="@(() => _workspaceViewMode = WorkspaceViewMode.Grid)" StartIcon="@Icons.Material.Filled.ViewList" title="List">List</MudButton>
        </MudButtonGroup>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadWorkspaces">Refresh</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="OpenCreateDialog">Create</MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
    }

    @if (_workspaceViewMode == WorkspaceViewMode.Cards)
    {
        <MudGrid Class="mt-4">
            @foreach (var row in _myWorkspacesGrid)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudCard Class="fill-height" Elevation="2">
                        <MudCardHeader>
                            @if (!string.IsNullOrWhiteSpace(row.Icon))
                            {
                                <MudIcon Icon="@row.Icon" Class="mr-2" Size="Size.Small" />
                            }
                            <MudLink Href="@MainRoutes.GetNotebooksRoute(row.Id)" Typo="Typo.h6" Style="font-weight: 500;">@row.Name</MudLink>
                        </MudCardHeader>
                        <MudCardContent Class="pt-0">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@(row.Description ?? "—")</MudText>
                        </MudCardContent>
                        <MudCardActions>
                            <MudIconButton Icon="@Icons.Material.Filled.List" Href="@MainRoutes.GetNotebooksRoute(row.Id)" Title="Notebooks" Size="Size.Small" />
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" OnClick="@(() => OpenEditDialog(row))" Title="Edit" Size="Size.Small" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" OnClick="@(() => ConfirmDelete(row))" Title="Delete" Color="Color.Error" Size="Size.Small" />
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
    else
    {
        <MudSimpleTable Class="mt-4" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Owner</th>
                    <th style="width:120px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in _myWorkspacesGrid)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(row.Icon))
                            {
                                <MudIcon Icon="@row.Icon" Size="Size.Small" Class="mr-1" />
                            }
                            <MudLink Href="@MainRoutes.GetNotebooksRoute(row.Id)" Typo="Typo.body1">@row.Name</MudLink>
                        </td>
                        <td><MudText Typo="Typo.body2" Color="Color.Secondary">@(row.Description ?? "—")</MudText></td>
                        <td><MudText Typo="Typo.body2">@(row.OwnerLogin ?? "—")</MudText></td>
                        <td>
                            <MudIconButton Icon="@Icons.Material.Filled.List" Href="@MainRoutes.GetNotebooksRoute(row.Id)" Size="Size.Small" title="Notebooks" />
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" OnClick="@(() => OpenEditDialog(row))" Size="Size.Small" title="Edit" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" OnClick="@(() => ConfirmDelete(row))" Size="Size.Small" Color="Color.Error" title="Delete" />
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }

    @if (!_loading && _myWorkspacesGrid.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Class="mt-4">No workspaces yet. Create one to organize your notebooks.</MudAlert>
    }
</MudPaper>

<MudDialog @bind-Visible="_showEditDialog" Options="@(new DialogOptions { CloseOnEscapeKey = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_isEdit ? "Edit workspace" : "New workspace")</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack @onkeydown="OnEditDialogKeyDown">
            <MudSwitch @bind-Value="_editIsFolder" Label="Folder (for grouping only)" Color="Color.Primary" Class="mt-2" Disabled="@_isEdit" />
            <MudTextField @bind-Value="_editName" Label="Name" Variant="Variant.Outlined" Class="mt-2" Required />
            <MudTextField @bind-Value="_editDescription" Label="Description" Variant="Variant.Outlined" Class="mt-2" Lines="2" />
            <MudTextField @bind-Value="_editIcon" Label="Icon (Material icon name, e.g. folder_special)" Variant="Variant.Outlined" Class="mt-2" Placeholder="folder" />
            <MudSelect T="WorkspaceVisibilityInfo" @bind-Value="_editVisibility" Label="Visibility" Variant="Variant.Outlined" Class="mt-2">
                <MudSelectItem T="WorkspaceVisibilityInfo" Value="@WorkspaceVisibilityInfo.Private">Private</MudSelectItem>
                <MudSelectItem T="WorkspaceVisibilityInfo" Value="@WorkspaceVisibilityInfo.Public">Public</MudSelectItem>
            </MudSelect>
            @if (_folderOptions.Count > 0)
            {
                <MudSelect T="Guid?" @bind-Value="_editParentId" Label="Parent folder" Variant="Variant.Outlined" Class="mt-2" Clearable="true">
                    <MudSelectItem T="Guid?" Value="null">— Root —</MudSelectItem>
                    @foreach (var f in _folderOptions)
                    {
                        <MudSelectItem T="Guid?" Value="@f.Id">@f.Name</MudSelectItem>
                    }
                </MudSelect>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseEditDialog">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveWorkspace">@(_isEdit ? "Save" : "Create")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<WorkspaceInfo> _workspaces = new();
    private List<WorkspaceInfo> _folderOptions = new();
    private bool _loading = true;
    private bool _showEditDialog;
    private bool _isEdit;
    private Guid _editId;
    private string _editName = "";
    private string? _editDescription;
    private bool _editIsFolder;
    private Guid? _editParentId;
    private string? _editIcon;
    private WorkspaceVisibilityInfo _editVisibility = WorkspaceVisibilityInfo.Private;

    private string? _workspaceSearch;
    private enum WorkspaceViewMode { Cards, Grid }
    private WorkspaceViewMode _workspaceViewMode = WorkspaceViewMode.Cards;
    private List<WorkspaceInfo> _myWorkspacesGrid => _workspaces
        .Where(x => !x.IsFolder)
        .Where(x => string.IsNullOrWhiteSpace(_workspaceSearch) || (x.Name?.Contains(_workspaceSearch!, StringComparison.OrdinalIgnoreCase) ?? false))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadWorkspaces();
    }

    private async Task LoadWorkspaces()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            _workspaces = (await WorkspaceManager.GetWorkspaces(CancellationToken.None)).ToList();
        }
        catch (HttpClientException<ProblemDetailsData>)
        {
            SnackbarExtensions.ShowPopupMessage(Snackbar, "Failed to load workspaces.", Severity.Error);
            _workspaces = new List<WorkspaceInfo>();
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void OpenCreateDialog()
    {
        _isEdit = false;
        _editId = default;
        _editName = "";
        _editDescription = null;
        _editIsFolder = false;
        _editParentId = null;
        _editIcon = null;
        _editVisibility = WorkspaceVisibilityInfo.Private;
        _folderOptions = _workspaces.Where(x => x.IsFolder).OrderBy(x => x.Name).ToList();
        _showEditDialog = true;
    }

    private void OpenEditDialog(WorkspaceInfo ws)
    {
        _isEdit = true;
        _editId = ws.Id;
        _editName = ws.Name ?? "";
        _editDescription = ws.Description;
        _editIsFolder = ws.IsFolder;
        _editParentId = ws.ParentId;
        _editIcon = ws.Icon;
        _editVisibility = ws.Visibility;
        _folderOptions = _workspaces.Where(x => x.IsFolder && x.Id != ws.Id).OrderBy(x => x.Name).ToList();
        _showEditDialog = true;
    }

    private void CloseEditDialog()
    {
        _showEditDialog = false;
    }

    private async Task OnEditDialogKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey && !string.IsNullOrWhiteSpace(_editName))
            await SaveWorkspace();
    }

    private async Task SaveWorkspace()
    {
        if (string.IsNullOrWhiteSpace(_editName))
        {
            SnackbarExtensions.ShowPopupMessage(Snackbar, "Enter workspace name.", Severity.Warning);
            return;
        }
        try
        {
            if (_isEdit)
            {
                await WorkspaceManager.UpdateWorkspace(_editId, new WorkspaceInfo
                {
                    Id = _editId,
                    Name = _editName.Trim(),
                    Description = string.IsNullOrWhiteSpace(_editDescription) ? null : _editDescription.Trim(),
                    ParentId = _editParentId,
                    IsFolder = _editIsFolder,
                    Icon = string.IsNullOrWhiteSpace(_editIcon) ? null : _editIcon.Trim(),
                    Visibility = _editVisibility,
                }, CancellationToken.None);
                SnackbarExtensions.ShowPopupMessage(Snackbar, "Workspace updated.", Severity.Success);
            }
            else
            {
                var created = await WorkspaceManager.CreateWorkspace(new WorkspaceInfo
                {
                    Name = _editName.Trim(),
                    Description = string.IsNullOrWhiteSpace(_editDescription) ? null : _editDescription.Trim(),
                    ParentId = _editParentId,
                    IsFolder = _editIsFolder,
                    Icon = string.IsNullOrWhiteSpace(_editIcon) ? null : _editIcon.Trim(),
                    Visibility = _editVisibility,
                }, CancellationToken.None);
                SnackbarExtensions.ShowPopupMessage(Snackbar, "Workspace created.", Severity.Success);
                _showEditDialog = false;
                await LoadWorkspaces();
                Navigation.NavigateTo(MainRoutes.GetNotebooksRoute(created.Id), forceLoad: false);
            }
        }
        catch (HttpClientException<ProblemDetailsData>)
        {
            SnackbarExtensions.ShowPopupMessage(Snackbar, _isEdit ? "Failed to update workspace." : "Failed to create workspace.", Severity.Error);
        }
    }

    private async Task ConfirmDelete(WorkspaceInfo ws)
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Delete workspace",
            $"Delete workspace \"{ws.Name}\"? Notebooks in this workspace will not be deleted but will have no workspace.",
            yesText: "Delete",
            cancelText: "Cancel");
        if (confirmed != true) return;
        try
        {
            await WorkspaceManager.DeleteWorkspace(ws.Id, CancellationToken.None);
            SnackbarExtensions.ShowPopupMessage(Snackbar, "Workspace deleted.", Severity.Success);
            await LoadWorkspaces();
        }
        catch (HttpClientException<ProblemDetailsData>)
        {
            SnackbarExtensions.ShowPopupMessage(Snackbar, "Failed to delete workspace.", Severity.Error);
        }
    }
}
