        return await Catalog.GetEntitySelectTextAsync(entityId, top, CancellationToken.None);
    }

    private async Task OpenAccessDialog()
    {
        if (_notebook == null || IsNew) return;
        try
        {
            var access = await NotebookManager.GetNotebookAccess(Id, CancellationToken.None);
            var model = new NotebookAccessDialog.NotebookAccessDialogModel
            {
                NotebookId = Id,
                NotebookName = _notebook.Name ?? "Notebook",
                Entries = access?.Entries?.ToList() ?? new List<NotebookAccessEntryInfo>()
            };

            var parameters = new DialogParameters
            {
                ["Model"] = model
            };
            var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
            var dialog = await DialogService.ShowAsync<NotebookAccessDialog>("Access", parameters, options);
            var result = await dialog.Result;
            if (!result.Canceled && result.Data is List<NotebookAccessEntryInfo> entries)
            {
                await NotebookManager.SetNotebookAccess(Id, entries, CancellationToken.None);
                SnackbarExtensions.ShowPopupMessage(Snackbar, "Access updated.", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            SnackbarExtensions.ShowPopupMessage(Snackbar, ex.Message, Severity.Error);
        }
    }
