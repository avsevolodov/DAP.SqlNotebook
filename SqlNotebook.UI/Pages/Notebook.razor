    private async Task SaveNotebookAfterCellUpdate()
    {
        if (_notebook == null) return;
        _ = ScheduleNotebookSaveDebounced();
        await InvokeAsync(StateHasChanged);
    }

    private async Task ScheduleNotebookSaveDebounced()
    {
        _saveDebounceCts?.Cancel();
        _saveDebounceCts?.Dispose();
        var cts = new CancellationTokenSource();
        _saveDebounceCts = cts;
        try
        {
            await Task.Delay(NotebookSaveDebounceMs, cts.Token);
        }
        catch (TaskCanceledException)
        {
            return;
        }
        if (cts.IsCancellationRequested || _notebook == null) return;
        await NotebookManager.UpdateNotebook(Id, _notebook, CancellationToken.None);
    }

    private async Task HandleDeleteCell(NotebookCellInfo cell)
    {
        if (_notebook?.Cells == null) return;
        _notebook.Cells.Remove(cell);
        _notebook = await NotebookManager.UpdateNotebook(Id, _notebook, CancellationToken.None);
        await InvokeAsync(StateHasChanged);
    }

