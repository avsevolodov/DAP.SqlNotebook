@namespace DAP.SqlNotebook.UI.Components
@using System.Threading
@using DAP.SqlNotebook.Contract.Entities
@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop
@using MudBlazor
@implements IDisposable

<MudPaper Class="@($"pa-3 notebook-cell-paper {( _isFullscreen ? "notebook-cell-fullscreen" : string.Empty)}")"
          Elevation="1"
          Outlined="true"
          Style="@(_isFullscreen
              ? "position:fixed; inset:0; z-index:1300; margin:0; border-radius:0; background-color: var(--mud-palette-background);"
              : null)">
    <MudStack Spacing="1" Style="@(_isFullscreen ? "height:100%; align-items:stretch;" : null)">
        <div class="notebook-cell-code-header d-flex align-items-center" style="gap: 8px;">
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Title="Delete cell" OnClick="DeleteCell" />
            <MudIconButton Icon="@Icons.Material.Filled.Save"
                           Size="Size.Small"
                           Disabled="@(!_isDirty)"
                           Title="Сохранить"
                           OnClick="SaveCell" />
            <MudIconButton Icon="@Icons.Material.Filled.UploadFile"
                           Size="Size.Small"
                           Title="Импортировать из файла"
                           OnClick="ImportFromFile" />
            @if (_isFullscreen)
            {
                <MudIconButton Icon="@Icons.Material.Filled.FullscreenExit"
                               Size="Size.Small"
                               Title="Закрыть полноэкранный режим (Esc)"
                               OnClick="ToggleFullscreen" />
            }
            else
            {
                <MudIconButton Icon="@Icons.Material.Filled.Fullscreen"
                               Size="Size.Small"
                               Title="Развернуть во весь экран"
                               OnClick="ToggleFullscreen" />
            }
            <MudText Typo="Typo.caption" Color="Color.Secondary">Excalidraw — диаграмма</MudText>
        </div>
        <div class="notebook-excalidraw-wrap"
             style="@(_isFullscreen ? "flex:1 1 auto; height:calc(100vh - 96px); min-height:300px;" : "height: 400px; min-height: 300px;")">
            <iframe id="@_iframeId"
                    src="excalidraw/embed.html"
                    title="Excalidraw diagram"
                    style="width: 100%; height: 100%; border: 1px solid var(--mud-palette-lines-default); border-radius: 4px; pointer-events: auto;"
                    @onload="HandleIframeLoad" />
        </div>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public NotebookCellInfo Cell { get; set; } = null!;
    [Parameter] public EventCallback<NotebookCellInfo> OnDeleteCell { get; set; }
    [Parameter] public EventCallback<(int CellId, string Content)> OnExcalidrawContentChanged { get; set; }
    [Parameter] public EventCallback<int> OnSaveRequested { get; set; }

    [Inject] private IJSRuntime JS { get; set; } = null!;

    private string _iframeId = "excalidraw-" + Guid.NewGuid().ToString("N")[..8];
    private DotNetObjectReference<NotebookExcalidrawCell>? _dotNetRef;
    private bool _listenerRegistered;
    private string? _lastSentContent;
    private bool _isFullscreen;
    private bool _isDirty;

    protected override void OnInitialized()
    {
        _dotNetRef = DotNetObjectReference.Create(this);
    }

    private async Task HandleIframeLoad()
    {
        try
        {
            if (!_listenerRegistered && _dotNetRef != null)
            {
                await JS.InvokeVoidAsync("sqlNotebookExcalidraw.listenForChanges", _iframeId, _dotNetRef, "OnExcalidrawChange", "OnExcalidrawReady", "OnExcalidrawEscape");
                _listenerRegistered = true;
            }
            _ = SendContentWhenReadyAsync();
            _ = InvokeAsync(async () =>
            {
                await Task.Delay(800);
                await SendContentWhenReadyAsync();
            });
        }
        catch (Exception) { /* iframe may not be ready */ }
    }

    [JSInvokable]
    public async Task OnExcalidrawReady()
    {
        await SendContentWhenReadyAsync();
    }

    private async Task SendContentWhenReadyAsync()
    {
        try
        {
            var content = Cell.Content ?? "";
            if (string.IsNullOrWhiteSpace(content))
                content = "{}";
            if (content != _lastSentContent)
            {
                await JS.InvokeVoidAsync("sqlNotebookExcalidraw.sendContent", _iframeId, content);
                _lastSentContent = content;
            }
        }
        catch (Exception) { /* ignore */ }
    }

    private void ToggleFullscreen()
    {
        _isFullscreen = !_isFullscreen;
    }

    [JSInvokable]
    public Task OnExcalidrawEscape()
    {
        _isFullscreen = false;
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnExcalidrawChange(string content)
    {
        if (string.IsNullOrEmpty(content)) return;
        _lastSentContent = content;
        _isDirty = true;
        Cell.Content = content;
        if (OnExcalidrawContentChanged.HasDelegate)
            await OnExcalidrawContentChanged.InvokeAsync((Cell.Id, content));
        await InvokeAsync(StateHasChanged);
    }

    private async Task SaveCell()
    {
        if (!OnSaveRequested.HasDelegate) return;
        await OnSaveRequested.InvokeAsync(Cell.Id);
        _isDirty = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task ImportFromFile()
    {
        try
        {
            await JS.InvokeVoidAsync("sqlNotebookExcalidraw.importFromFile", _iframeId);
        }
        catch { }
    }

    private async Task DeleteCell()
    {
        if (OnDeleteCell.HasDelegate)
            await OnDeleteCell.InvokeAsync(Cell);
    }

    public void Dispose()
    {
        try
        {
            _ = JS.InvokeVoidAsync("sqlNotebookExcalidraw.stopListen", _iframeId);
        }
        catch { }
        _dotNetRef?.Dispose();
    }
}
