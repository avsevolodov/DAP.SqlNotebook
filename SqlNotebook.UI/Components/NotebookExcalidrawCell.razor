@namespace DAP.SqlNotebook.UI.Components
@using System.Threading
@using DAP.SqlNotebook.Contract.Entities
@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop
@using MudBlazor
@implements IDisposable

<MudPaper Class="pa-3 notebook-cell-paper" Elevation="1" Outlined="true">
    <MudStack Spacing="1">
        <div class="notebook-cell-code-header d-flex align-items-center" style="gap: 8px;">
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Title="Delete cell" OnClick="DeleteCell" />
            <MudIconButton Icon="@Icons.Material.Filled.Fullscreen" Size="Size.Small" Title="Развернуть во весь экран" OnClick="OpenFullscreen" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Excalidraw — диаграмма</MudText>
        </div>
        <div class="notebook-excalidraw-wrap" style="height: 400px; min-height: 300px;">
            <iframe id="@_iframeId"
                    src="excalidraw/embed.html"
                    title="Excalidraw diagram"
                    style="width: 100%; height: 100%; border: 1px solid var(--mud-palette-lines-default); border-radius: 4px; pointer-events: auto;"
                    @onload="HandleIframeLoad" />
        </div>
    </MudStack>
    <MudDialog @bind-Visible="_fullscreenOpen" FullScreen="true" Options="new DialogOptions { CloseButton = true }">
        <TitleContent>
            <MudText Typo="Typo.h6">Excalidraw — на весь экран</MudText>
        </TitleContent>
        <DialogContent>
            <div class="notebook-excalidraw-fullscreen" style="width: 100%; height: calc(100vh - 120px); min-height: 400px;">
                <iframe id="@_fullscreenIframeId"
                        src="excalidraw/embed.html"
                        title="Excalidraw fullscreen"
                        style="width: 100%; height: 100%; border: none; pointer-events: auto;"
                        @onload="HandleFullscreenIframeLoad" />
            </div>
        </DialogContent>
        <DialogActions>
            <MudButton Variant="Variant.Filled" OnClick="CloseFullscreen">Закрыть и сохранить</MudButton>
        </DialogActions>
    </MudDialog>
</MudPaper>

@code {
    [Parameter, EditorRequired] public NotebookCellInfo Cell { get; set; } = null!;
    [Parameter] public EventCallback<NotebookCellInfo> OnDeleteCell { get; set; }
    [Parameter] public EventCallback<(int CellId, string Content)> OnExcalidrawContentChanged { get; set; }
    [Parameter] public EventCallback OnCellUpdated { get; set; }

    [Inject] private IJSRuntime JS { get; set; } = null!;

    private string _iframeId = "excalidraw-" + Guid.NewGuid().ToString("N")[..8];
    private string _fullscreenIframeId = "excalidraw-fs-" + Guid.NewGuid().ToString("N")[..8];
    private DotNetObjectReference<NotebookExcalidrawCell>? _dotNetRef;
    private bool _listenerRegistered;
    private string? _lastSentContent;
    private bool _fullscreenOpen;
    private bool _fullscreenListenerRegistered;

    protected override void OnInitialized()
    {
        _dotNetRef = DotNetObjectReference.Create(this);
    }

    private async Task HandleIframeLoad()
    {
        try
        {
            if (!_listenerRegistered)
            {
                await JS.InvokeVoidAsync("sqlNotebookExcalidraw.listenForChanges", _iframeId, _dotNetRef);
                _listenerRegistered = true;
            }
            var content = Cell.Content ?? "";
            if (string.IsNullOrWhiteSpace(content))
                content = "{}";
            if (content != _lastSentContent)
            {
                await JS.InvokeVoidAsync("sqlNotebookExcalidraw.sendContent", _iframeId, content);
                _lastSentContent = content;
            }
        }
        catch (Exception) { /* iframe may not be ready */ }
    }

    private void OpenFullscreen()
    {
        _fullscreenOpen = true;
    }

    private async Task HandleFullscreenIframeLoad()
    {
        try
        {
            if (!_fullscreenListenerRegistered)
            {
                await JS.InvokeVoidAsync("sqlNotebookExcalidraw.listenForChanges", _fullscreenIframeId, _dotNetRef, "OnExcalidrawFullscreenChange");
                _fullscreenListenerRegistered = true;
            }
            var content = Cell.Content ?? "";
            if (string.IsNullOrWhiteSpace(content))
                content = "{}";
            await JS.InvokeVoidAsync("sqlNotebookExcalidraw.sendContent", _fullscreenIframeId, content);
        }
        catch (Exception) { }
    }

    private async Task CloseFullscreen()
    {
        try
        {
            await JS.InvokeVoidAsync("sqlNotebookExcalidraw.requestContent", _fullscreenIframeId);
        }
        catch { }
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnExcalidrawFullscreenChange(string content)
    {
        if (string.IsNullOrEmpty(content)) return;
        _lastSentContent = content;
        if (OnExcalidrawContentChanged.HasDelegate)
            await OnExcalidrawContentChanged.InvokeAsync((Cell.Id, content));
        if (OnCellUpdated.HasDelegate)
            await OnCellUpdated.InvokeAsync();
        try
        {
            await JS.InvokeVoidAsync("sqlNotebookExcalidraw.sendContent", _iframeId, content);
        }
        catch { }
        _fullscreenOpen = false;
        if (_fullscreenListenerRegistered)
        {
            try { await JS.InvokeVoidAsync("sqlNotebookExcalidraw.stopListen", _fullscreenIframeId); } catch { }
            _fullscreenListenerRegistered = false;
        }
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnExcalidrawChange(string content)
    {
        if (string.IsNullOrEmpty(content)) return;
        _lastSentContent = content;
        if (OnExcalidrawContentChanged.HasDelegate)
            await OnExcalidrawContentChanged.InvokeAsync((Cell.Id, content));
        if (OnCellUpdated.HasDelegate)
            await OnCellUpdated.InvokeAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task DeleteCell()
    {
        if (OnDeleteCell.HasDelegate)
            await OnDeleteCell.InvokeAsync(Cell);
    }

    public void Dispose()
    {
        try
        {
            _ = JS.InvokeVoidAsync("sqlNotebookExcalidraw.stopListen", _iframeId);
        }
        catch { }
        _dotNetRef?.Dispose();
    }
}
