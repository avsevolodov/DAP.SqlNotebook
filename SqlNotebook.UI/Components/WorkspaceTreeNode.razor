@using System.Collections.Generic
@using DAP.SqlNotebook.Contract.Entities
@using DAP.SqlNotebook.Service.Client.V1
@using DAP.SqlNotebook.UI.Helpers
@using Microsoft.AspNetCore.Components
@using MudBlazor

@* Recursive tree node: folder (with children) or workspace (with notebooks on expand). *@
<div class="workspaces-tree-node">
    @if (Node.IsFolder)
    {
        var expanded = Expanded.Contains(Node.Id);
        var children = AllNodes.Where(x => x.ParentId == Node.Id).OrderBy(x => x.Name).ToList();
        <div class="workspaces-tree-row" style="@($"padding-left: {PaddingLeft}px;")" @onclick="@HandleToggle">
            <span class="material-icons workspaces-tree-icon" aria-hidden="true">@(expanded ? "expand_more" : "chevron_right")</span>
            <span class="material-icons workspaces-tree-icon" style="color: var(--mud-palette-primary);" aria-hidden="true">folder</span>
            <span class="workspaces-tree-name" style="font-weight: 500;">@(Node.Name ?? "Folder")</span>
        </div>
        @if (expanded && children.Count > 0)
        {
            @foreach (var child in children)
            {
                <WorkspaceTreeNode Node="@child"
                                 AllNodes="@AllNodes"
                                 Expanded="@Expanded"
                                 PaddingLeft="@(PaddingLeft + 24)"
                                 ToggleExpand="@ToggleExpand"
                                 NotebooksByWorkspace="@NotebooksByWorkspace"
                                 LoadingNotebooks="@LoadingNotebooks"
                                 FavoriteIds="@FavoriteIds"
                                 ToggleFavorite="@ToggleFavorite" />
            }
        }
    }
    else
    {
        var expanded = Expanded.Contains(Node.Id);
        var isFavorite = FavoriteIds?.Contains(Node.Id) ?? false;
        <div class="workspaces-tree-row" style="@($"padding-left: {PaddingLeft}px;")" @onclick="@HandleToggle">
            <span class="material-icons workspaces-tree-icon" aria-hidden="true">@(expanded ? "expand_more" : "chevron_right")</span>
            <span class="material-icons workspaces-tree-icon" style="color: var(--mud-palette-primary);" aria-hidden="true">folder_open</span>
            <a href="@MainRoutes.GetNotebooksRoute(Node.Id)" class="workspaces-tree-name" @onclick:stopPropagation="true">@(Node.Name ?? "Workspace")</a>
            @if (FavoriteIds != null)
            {
                <span class="material-icons workspaces-tree-icon" style="color: var(--mud-palette-warning); margin-left: auto; cursor: pointer; font-size: 18px;" aria-hidden="true" title="@(isFavorite ? "Remove from favorites" : "Add to favorites")" @onclick="@HandleToggleFavorite" @onclick:stopPropagation="true">@(isFavorite ? "star" : "star_border")</span>
            }
        </div>
        @if (expanded)
        {
            @if (LoadingNotebooks == Node.Id)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Style="@($"height: 2px; margin-left: {PaddingLeft + 24}px;")" />
            }
            else
            {
                var notebooks = NotebooksByWorkspace.TryGetValue(Node.Id, out var list) ? list : null;
                @if (notebooks != null)
                {
                    @foreach (var nb in notebooks)
                    {
                        <div class="workspaces-tree-row workspaces-tree-notebook" style="@($"padding-left: {PaddingLeft + 24}px; min-height: 28px;")">
                            <span class="material-icons workspaces-tree-icon" style="color: var(--mud-palette-secondary); font-size: 20px;" aria-hidden="true">menu_book</span>
                            <a href="@MainRoutes.GetNotebookRoute(nb.Id)" class="workspaces-tree-name" title="@nb.Name">@nb.Name</a>
                        </div>
                    }
                    @if (notebooks.Count == 0)
                    {
                        <div class="workspaces-tree-row" style="@($"padding-left: {PaddingLeft + 24}px; color: var(--mud-palette-text-secondary); font-size: 0.875rem;")">No notebooks</div>
                    }
                }
            }
        }
    }
</div>

@code {
    [Parameter] public WorkspaceInfo Node { get; set; } = null!;
    [Parameter] public IReadOnlyList<WorkspaceInfo> AllNodes { get; set; } = null!;
    [Parameter] public HashSet<Guid> Expanded { get; set; } = null!;
    [Parameter] public int PaddingLeft { get; set; }
    [Parameter] public EventCallback<Guid> ToggleExpand { get; set; }
    [Parameter] public IReadOnlyDictionary<Guid, List<NotebookMetaInfo>> NotebooksByWorkspace { get; set; } = null!;
    [Parameter] public Guid? LoadingNotebooks { get; set; }
    [Parameter] public HashSet<Guid>? FavoriteIds { get; set; }
    [Parameter] public EventCallback<Guid> ToggleFavorite { get; set; }

    private async Task HandleToggle() => await ToggleExpand.InvokeAsync(Node.Id);

    private async Task HandleToggleFavorite()
    {
        if (FavoriteIds != null)
            await ToggleFavorite.InvokeAsync(Node.Id);
    }
}
