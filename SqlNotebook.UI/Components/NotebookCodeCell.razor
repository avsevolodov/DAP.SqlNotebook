@namespace DAP.SqlNotebook.UI.Components
@using System.Linq
@using System.Threading
@using DAP.SqlNotebook.Contract.Entities
@using DAP.SqlNotebook.Service.Client.V1
@using DAP.SqlNotebook.UI.Helpers
@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop
@using MudBlazor

<MudPaper Class="pa-3 notebook-cell-paper" Elevation="1" Outlined="true">
    <MudStack Spacing="1">
        <div class="notebook-cell-code-frame notebook-cell-header-section">
            <div class="notebook-cell-code-header d-flex align-items-center flex-wrap" style="gap: 6px;">
                @* Common: collapse *@
                <MudIconButton Icon="@(_collapsed ? Icons.Material.Filled.ExpandMore : Icons.Material.Filled.ExpandLess)"
                               Size="Size.Small" Title="@(_collapsed ? "Expand" : "Collapse")" OnClick="ToggleCollapsed" />

                @if (_editingTitle)
                {
                    <MudTextField Value="@_titleEdit"
                                  ValueChanged="@(EventCallback.Factory.Create<string>(this, OnTitleEditingChanged))"
                                  Placeholder="Title"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Class="ml-2 notebook-cell-title-input"
                                  Style="max-width: 260px;"
                                  Immediate="true" />
                    <MudIconButton Icon="@Icons.Material.Filled.Check"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   Title="Save title"
                                   OnClick="SaveTitleAsync" />
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Size="Size.Small"
                                   Title="Cancel"
                                   OnClick="CancelEditTitle" />
                }
                else
                {
                    <MudText Typo="Typo.caption"
                             Class="ml-2 notebook-cell-title"
                             Style="max-width: 260px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                        @GetTitle()
                    </MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Size="Size.Small"
                                   Title="Edit title"
                                   OnClick="StartEditTitle" />
                }
                @if (!string.IsNullOrWhiteSpace(Cell.DatabaseDisplayName))
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Class="notebook-cell-db-chip">@Cell.DatabaseDisplayName</MudChip>
                }
                <div class="flex-grow-1"></div>
                @* Type-specific: Run, Copy, Paste to editor; Chart type (SQL only); Move/Copy cell; Delete on the right *@
                @if (!_collapsed)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" Title="Run" OnClick="RunCell" Disabled="@(_running || IsExternalRunning)" />
                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small" Title="Copy" OnClick="@(() => CopyContent(Cell.Content))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Title="Paste to editor" OnClick="@(() => PasteToEditor(Cell.Content))" />
                    <MudIconButton Icon="@Icons.Material.Filled.FormatAlignLeft" Size="Size.Small" Title="Format" OnClick="@(() => FormatCell())" />

                    <MudIconButton Icon="@Icons.Material.Filled.FormatListNumbered"
                                   Size="Size.Small"
                                   Color="@(_showLineNumbers ? Color.Primary : Color.Default)"
                                   Title="@(_showLineNumbers ? "Hide line numbers" : "Show line numbers")"
                                   OnClick="@ToggleLineNumbers" />

                    @if (Cell.Type == NotebookCellTypeInfo.Sql && Cell.ExecutionResult != null && Cell.ExecutionResult.Columns != null && Cell.ExecutionResult.Columns.Length > 0)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.TableChart"
                                       Size="Size.Small"
                                       Color="@(IsChartTypeSelected("table") ? Color.Primary : Color.Default)"
                                       Title="Chart type: Table"
                                       OnClick="SetChartTypeTable" />
                        <MudIconButton Icon="@Icons.Material.Filled.ShowChart"
                                       Size="Size.Small"
                                       Color="@(IsChartTypeSelected("line") ? Color.Primary : Color.Default)"
                                       Title="Chart type: Line"
                                       Disabled="@(!_canShowLineChart)"
                                       OnClick="SetChartTypeLine" />
                        <MudIconButton Icon="@Icons.Material.Filled.BarChart"
                                       Size="Size.Small"
                                       Color="@(IsChartTypeSelected("bar") ? Color.Primary : Color.Default)"
                                       Title="Chart type: Bar"
                                       Disabled="@(!_canShowBarChart)"
                                       OnClick="SetChartTypeBar" />
                        <MudIconButton Icon="@Icons.Material.Filled.PieChart"
                                       Size="Size.Small"
                                       Color="@(IsChartTypeSelected("pie") ? Color.Primary : Color.Default)"
                                       Title="Chart type: Pie"
                                       Disabled="@(!_canShowPieChart)"
                                       OnClick="SetChartTypePie" />
                        <MudIconButton Icon="@Icons.Material.Filled.Download"
                                       Size="Size.Small"
                                       Title="Download CSV (full result)"
                                       OnClick="DownloadCellResultCsv" />
                    }

                    <MudIconButton Icon="@Icons.Material.Filled.FileCopy"
                                   Size="Size.Small"
                                   Title="Copy cell"
                                   OnClick="CopyCell" />
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward"
                                   Size="Size.Small"
                                   Disabled="@(!CanMoveUp)"
                                   Title="Move up"
                                   OnClick="MoveUp" />
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward"
                                   Size="Size.Small"
                                   Disabled="@(!CanMoveDown)"
                                   Title="Move down"
                                   OnClick="MoveDown" />

                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" Title="Delete cell" OnClick="DeleteCell" />
                }
            </div>
            @if (!_collapsed)
            {
                <pre class="notebook-cell-code mud-typography mud-typography-body2"><code class="language-sql">@Cell.Content</code></pre>
            }
            else
            {
                <div class="notebook-cell-collapsed-preview">@GetCollapsedPreview()</div>
            }
        </div>
        @if (!_collapsed)
        {
            <div class="notebook-cell-result-wrap" style="position: relative;">
                @if (_running || IsExternalRunning)
                {
                    <div class="notebook-cell-result-overlay">
                        <MudProgressCircular Size="Size.Large" Indeterminate="true" Color="Color.Primary" />
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">Running…</MudText>
                        @if (_running)
                        {
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small" Class="mt-2" StartIcon="@Icons.Material.Filled.Stop" OnClick="CancelRun">Cancel</MudButton>
                        }
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(_cellError))
                {
                    <MudAlert Severity="Severity.Error" Class="mt-2" Dismissible="true" OnClose="ClearCellError">@_cellError</MudAlert>
                }
                <NotebookQueryResult Result="@Cell.ExecutionResult"
                                     MaxHeight="300"
                                     ForceTable="@(_resultView == ResultViewMode.Table)" />
            </div>
        }
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public NotebookCellInfo Cell { get; set; } = null!;
    [Parameter, EditorRequired] public Guid NotebookId { get; set; }
    [Parameter] public int? QueryTimeoutSeconds { get; set; }
    [Parameter] public int SelectTopCount { get; set; } = 10;
    [Parameter] public CatalogNodeInfo? SelectedDatabase { get; set; }
    [Parameter] public EventCallback<(int CellId, string ChartType)> OnChartTypeChanged { get; set; }
    [Parameter] public EventCallback<(int CellId, string FormattedContent)> OnFormatCell { get; set; }
    [Parameter] public EventCallback<NotebookCellInfo> OnDeleteCell { get; set; }
    [Parameter] public EventCallback<string> OnInsertIntoEditor { get; set; }
    [Parameter] public EventCallback OnCellUpdated { get; set; }
    [Parameter] public EventCallback OnCopyCell { get; set; }
    [Parameter] public EventCallback OnMoveUp { get; set; }
    [Parameter] public EventCallback OnMoveDown { get; set; }
    [Parameter] public bool CanMoveUp { get; set; }
    [Parameter] public bool CanMoveDown { get; set; }
    [Parameter] public bool IsExternalRunning { get; set; }

    [Inject] private INotebookManager NotebookManager { get; set; } = null!;
    [Inject] private IJSRuntime JS { get; set; } = null!;

    private bool _collapsed;
    private bool _running;
    private string? _cellError;
    private CancellationTokenSource? _runCts;

    private enum ResultViewMode
    {
        Table,
        Charts
    }

    private ResultViewMode _resultView = ResultViewMode.Table;

    private bool _showLineNumbers;
    private bool _editingTitle;
    private string? _titleEdit;
    private bool _canShowLineChart;
    private bool _canShowBarChart;
    private bool _canShowPieChart;

    private string GetTitle()
    {
        if (!string.IsNullOrWhiteSpace(Cell.Title))
        {
            var trimmed = Cell.Title.Trim();
            return trimmed.Length > 40 ? trimmed[..37] + "…" : trimmed;
        }
        if (!string.IsNullOrWhiteSpace(Cell.Content))
        {
            var firstLine = Cell.Content.TrimStart().Split('\n').FirstOrDefault()?.Trim() ?? "";
            if (firstLine.Length > 40)
                firstLine = firstLine[..37] + "…";
            if (!string.IsNullOrEmpty(firstLine))
                return firstLine;
        }
        return Cell.Type switch
        {
            NotebookCellTypeInfo.Sql => "SQL",
            _ => "Cell"
        };
    }

    private void ToggleLineNumbers() => _showLineNumbers = !_showLineNumbers;

    private async Task CopyCell()
    {
        if (OnCopyCell.HasDelegate)
            await OnCopyCell.InvokeAsync();
    }

    private async Task MoveUp()
    {
        if (OnMoveUp.HasDelegate)
            await OnMoveUp.InvokeAsync();
    }

    private async Task MoveDown()
    {
        if (OnMoveDown.HasDelegate)
            await OnMoveDown.InvokeAsync();
    }

    private IReadOnlyList<(int Number, string Text)> GetCodeLines()
    {
        var text = Cell.Content ?? string.Empty;
        var lines = text.Replace("\r\n", "\n").Split('\n');
        return lines
            .Select((t, i) => (Number: i + 1, Text: t))
            .ToList();
    }

    private void ToggleCollapsed() => _collapsed = !_collapsed;

    private string GetCollapsedPreview()
    {
        if (string.IsNullOrWhiteSpace(Cell.Content)) return "—";
        var first = Cell.Content.TrimStart().Split('\n').FirstOrDefault()?.Trim() ?? "";
        return first.Length > 80 ? first[..77] + "…" : first;
    }

    private int _prevCellId = -1;
    private string? _prevContent;
    private string? _prevTitle;
    private object? _prevExecutionResultRef;
    private string? _prevDatabaseDisplayName;
    private bool _prevRunning;
    private string? _prevCellError;
    private bool _prevCollapsed;

    protected override bool ShouldRender()
    {
        bool cellChanged = Cell.Id != _prevCellId
            || Cell.Content != _prevContent
            || Cell.Title != _prevTitle
            || !ReferenceEquals(Cell.ExecutionResult, _prevExecutionResultRef)
            || Cell.DatabaseDisplayName != _prevDatabaseDisplayName
            || _running != _prevRunning
            || _cellError != _prevCellError
            || _collapsed != _prevCollapsed;
        if (cellChanged)
        {
            _prevCellId = Cell.Id;
            _prevContent = Cell.Content;
            _prevTitle = Cell.Title;
            _prevExecutionResultRef = Cell.ExecutionResult;
            _prevDatabaseDisplayName = Cell.DatabaseDisplayName;
            _prevRunning = _running;
            _prevCellError = _cellError;
            _prevCollapsed = _collapsed;
        }
        return cellChanged;
    }

    private void UpdateChartCapabilities()
    {
        _canShowLineChart = _canShowBarChart = _canShowPieChart = false;
        var result = Cell.ExecutionResult;
        if (result?.Columns == null || result.Columns.Length == 0 || result.Rows == null || result.Rows.Length == 0)
            return;

        var colCount = result.Columns.Length;
        var rows = result.Rows;
        var bestNumericCount = 0;

        for (var c = 0; c < colCount; c++)
        {
            var numericCount = 0;
            foreach (var row in rows)
            {
                var values = row.Values?.ToList() ?? new List<string>();
                var cell = c < values.Count ? values[c] ?? string.Empty : string.Empty;
                if (TryParseDouble(cell, out _))
                    numericCount++;
            }

            if (numericCount > 0)
            {
                _canShowLineChart = true;
                _canShowBarChart = true;
                if (numericCount > bestNumericCount)
                    bestNumericCount = numericCount;
            }
        }

        _canShowPieChart = bestNumericCount > 0;
    }

    private static bool TryParseDouble(string? text, out double value)
    {
        return double.TryParse(
            text?.Trim(),
            System.Globalization.NumberStyles.Float | System.Globalization.NumberStyles.AllowThousands,
            System.Globalization.CultureInfo.InvariantCulture,
            out value);
    }

    private async Task RunCell()
    {
        if (string.IsNullOrWhiteSpace(Cell.Content) || _running) return;
        _cellError = null;
        _runCts?.Dispose();
        _runCts = new CancellationTokenSource();
        _running = true;
        try
        {
            StateHasChanged();
            var timeout = QueryTimeoutSeconds ?? 30;
            var top = Math.Clamp(SelectTopCount, 1, 10000);
            var result = await NotebookManager.ExecuteQuery(NotebookId, Cell.Content.Trim(), _runCts.Token, timeout, Cell.CatalogNodeId ?? SelectedDatabase?.Id, top);
            if (result.Status == NotebookCellExecutionStatusInfo.Failed)
            {
                _cellError = result.Error ?? "Execution failed.";
                return;
            }
            if (!string.IsNullOrEmpty(Cell.ExecutionResult?.ChartType))
                result.ChartType = Cell.ExecutionResult.ChartType;
            Cell.ExecutionResult = result;
            if (Cell.CatalogNodeId == null && SelectedDatabase != null)
            {
                Cell.CatalogNodeId = SelectedDatabase.Id;
                Cell.DatabaseDisplayName = SelectedDatabase.DatabaseName ?? SelectedDatabase.Name;
            }
            UpdateChartCapabilities();
            if (OnCellUpdated.HasDelegate)
                await OnCellUpdated.InvokeAsync();
        }
        catch (OperationCanceledException)
        {
            _cellError = "Query was cancelled.";
        }
        catch (Exception ex)
        {
            _cellError = ex.Message;
        }
        finally
        {
            _running = false;
            _runCts?.Dispose();
            _runCts = null;
            StateHasChanged();
        }
    }

    private async Task CopyContent(string? content)
    {
        if (string.IsNullOrEmpty(content)) return;
        try
        {
            await JS.InvokeVoidAsync("sqlNotebookCopyToClipboard", content);
        }
        catch { }
    }

    private async Task PasteToEditor(string content)
    {
        if (OnInsertIntoEditor.HasDelegate)
            await OnInsertIntoEditor.InvokeAsync(content ?? "");
    }

    private async Task FormatCell()
    {
        if (Cell.Type != NotebookCellTypeInfo.Sql) return;
        var formatted = SqlFormatterHelper.Format(Cell.Content);
        if (formatted == Cell.Content) return;
        if (OnFormatCell.HasDelegate)
            await OnFormatCell.InvokeAsync((Cell.Id, formatted));
    }

    private async Task DeleteCell()
    {
        if (OnDeleteCell.HasDelegate)
            await OnDeleteCell.InvokeAsync(Cell);
    }

    private void CancelRun()
    {
        _runCts?.Cancel();
    }

    private async Task ClearCellError()
    {
        _cellError = null;
        await InvokeAsync(StateHasChanged);
    }

    private void StartEditTitle()
    {
        _titleEdit = Cell.Title ?? string.Empty;
        _editingTitle = true;
    }

    private void CancelEditTitle()
    {
        _editingTitle = false;
    }

    private void OnTitleEditingChanged(string value)
    {
        _titleEdit = value;
    }

    private async Task SaveTitleAsync()
    {
        var newTitle = string.IsNullOrWhiteSpace(_titleEdit) ? null : _titleEdit.Trim();
        if (Cell.Title == newTitle)
        {
            _editingTitle = false;
            return;
        }

        Cell.Title = newTitle;
        _editingTitle = false;

        if (OnCellUpdated.HasDelegate)
            await OnCellUpdated.InvokeAsync();
    }

        private string GetCurrentChartType()
        {
            return (Cell.ExecutionResult?.ChartType ?? string.Empty).Trim().ToLowerInvariant();
        }

        private bool IsChartTypeSelected(string chartType)
        {
            var current = GetCurrentChartType();
            if (string.IsNullOrEmpty(current) && chartType == "line")
                return _resultView == ResultViewMode.Charts;
            return current == chartType;
        }

        private Task SetChartTypeTable() => SetChartTypeInternal("table");
        private Task SetChartTypeLine() => SetChartTypeInternal("line");
        private Task SetChartTypeBar() => SetChartTypeInternal("bar");
        private Task SetChartTypePie() => SetChartTypeInternal("pie");

        private async Task DownloadCellResultCsv()
        {
            if (string.IsNullOrWhiteSpace(Cell.Content)) return;
            var path = $"/api/v1/notebooks/{NotebookId}/execute/export-csv";
            var body = new { Query = Cell.Content.Trim(), CommandTimeoutSeconds = QueryTimeoutSeconds ?? 30, CatalogNodeId = Cell.CatalogNodeId ?? SelectedDatabase?.Id };
            await JS.InvokeVoidAsync("sqlNotebookDownloadCsv", path, body);
        }

        private async Task SetChartTypeInternal(string chartType)
        {
            if (Cell.ExecutionResult == null)
                return;

            Cell.ExecutionResult.ChartType = chartType;

            if (chartType == "table")
                _resultView = ResultViewMode.Table;
            else
                _resultView = ResultViewMode.Charts;

            if (OnChartTypeChanged.HasDelegate)
                await OnChartTypeChanged.InvokeAsync((Cell.Id, chartType));
        }
}
