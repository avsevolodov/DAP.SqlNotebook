@namespace DAP.SqlNotebook.UI.Components
@using DAP.SqlNotebook.Contract.Entities
@using Microsoft.AspNetCore.Components
@using MudBlazor
@using global::SqlNotebook.Mermaid.Components

<MudPaper Class="pa-3 notebook-cell-paper" Elevation="1" Outlined="true">
    <MudStack Spacing="2">
        <div class="d-flex align-items-center flex-wrap" style="gap: 8px;">
            <MudIconButton Icon="@(_collapsed ? Icons.Material.Filled.ExpandMore : Icons.Material.Filled.ExpandLess)"
                           Size="Size.Small"
                           Title="@(_collapsed ? "Expand" : "Collapse")"
                           OnClick="ToggleCollapsed" />
            <MudText Typo="Typo.caption"
                     Class="ml-2 notebook-cell-title"
                     Style="max-width: 260px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                @GetTitle()
            </MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">Mermaid — diagram</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Save"
                           Size="Size.Small"
                           Disabled="@(!_isDirty)"
                           Title="Save"
                           OnClick="Save" />
            <div class="flex-grow-1"></div>
            @if (!_collapsed)
            {
                <MudIconButton Icon="@Icons.Material.Filled.FileCopy" Size="Size.Small" Title="Copy cell" OnClick="CopyCell" />
                <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small" Disabled="@(!CanMoveUp)" Title="Move up" OnClick="MoveUp" />
                <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Small" Disabled="@(!CanMoveDown)" Title="Move down" OnClick="MoveDown" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" Title="Delete cell" OnClick="DeleteCell" />
            }
        </div>
        @if (!_collapsed)
        {
            <MudTextField Value="@Cell.Content"
                          ValueChanged="@(EventCallback.Factory.Create<string>(this, HandleContentChanged))"
                          Label="Mermaid code"
                          Variant="Variant.Outlined"
                          Lines="6"
                          Placeholder="graph TD&#10;  A --> B"
                          Immediate="true" />
            @if (!string.IsNullOrWhiteSpace(Cell.Content))
            {
                <div class="mermaid-cell-preview mt-2">
                    <MermaidDiagram Text="@Cell.Content" CssClass="mermaid-cell-diagram" />
                </div>
            }
        }
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public NotebookCellInfo Cell { get; set; } = null!;
    [Parameter] public EventCallback<NotebookCellInfo> OnDeleteCell { get; set; }
    [Parameter] public EventCallback<(int CellId, string Content)> OnContentChanged { get; set; }
    [Parameter] public EventCallback OnCopyCell { get; set; }
    [Parameter] public EventCallback OnMoveUp { get; set; }
    [Parameter] public EventCallback OnMoveDown { get; set; }
    [Parameter] public bool CanMoveUp { get; set; }
    [Parameter] public bool CanMoveDown { get; set; }

    private bool _collapsed;
    private bool _isDirty;

    private void ToggleCollapsed() => _collapsed = !_collapsed;

    private async Task HandleContentChanged(string value)
    {
        Cell.Content = value ?? "";
        _isDirty = true;
    }

    private async Task Save()
    {
        if (!_isDirty)
            return;
        if (OnContentChanged.HasDelegate)
            await OnContentChanged.InvokeAsync((Cell.Id, Cell.Content ?? ""));
        _isDirty = false;
    }

    private async Task DeleteCell()
    {
        if (OnDeleteCell.HasDelegate)
            await OnDeleteCell.InvokeAsync(Cell);
    }

    private async Task CopyCell()
    {
        if (OnCopyCell.HasDelegate)
            await OnCopyCell.InvokeAsync();
    }

    private async Task MoveUp()
    {
        if (OnMoveUp.HasDelegate)
            await OnMoveUp.InvokeAsync();
    }

    private async Task MoveDown()
    {
        if (OnMoveDown.HasDelegate)
            await OnMoveDown.InvokeAsync();
    }

    private string GetTitle()
    {
        if (!string.IsNullOrWhiteSpace(Cell.Title))
        {
            var trimmed = Cell.Title.Trim();
            return trimmed.Length > 40 ? trimmed[..37] + "…" : trimmed;
        }
        if (!string.IsNullOrWhiteSpace(Cell.Content))
        {
            var firstLine = Cell.Content.TrimStart().Split('\n').FirstOrDefault()?.Trim() ?? "";
            if (firstLine.Length > 40)
                firstLine = firstLine[..37] + "…";
            if (!string.IsNullOrEmpty(firstLine))
                return firstLine;
        }
        return "Mermaid";
    }
}
