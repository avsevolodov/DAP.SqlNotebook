@namespace DAP.SqlNotebook.UI.Components
@using DAP.SqlNotebook.Contract.Entities
@using Microsoft.AspNetCore.Components
@using MudBlazor
@using MudBlazor.Services

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudText Typo="Typo.subtitle2">@Model.NotebookName</MudText>

            <MudPaper Class="pa-2" Outlined="true">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Add user</MudText>
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                        <MudTextField T="string" @bind-Value="_newLogin" Label="Login" Variant="Variant.Outlined" Dense="true" Style="min-width: 220px;" />
                        <MudSelect T="NotebookAccessRoleInfo" @bind-Value="_newRole" Label="Role" Variant="Variant.Outlined" Dense="true" Style="min-width: 160px;">
                            <MudSelectItem Value="@NotebookAccessRoleInfo.Viewer">Viewer</MudSelectItem>
                            <MudSelectItem Value="@NotebookAccessRoleInfo.Editor">Editor</MudSelectItem>
                        </MudSelect>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddEntry" Disabled="@string.IsNullOrWhiteSpace(_newLogin)">Add</MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>

            <MudDivider />

            @if (_entries.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">No access entries.</MudText>
            }
            else
            {
                <MudTable Items="_entries" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>User</MudTh>
                        <MudTh>Role</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="User">@context.UserLogin</MudTd>
                        <MudTd DataLabel="Role">
                            <MudSelect T="NotebookAccessRoleInfo" Value="@context.Role" ValueChanged="@(v => UpdateRole(context, v))" Dense="true" Variant="Variant.Outlined">
                                <MudSelectItem Value="@NotebookAccessRoleInfo.Viewer">Viewer</MudSelectItem>
                                <MudSelectItem Value="@NotebookAccessRoleInfo.Editor">Editor</MudSelectItem>
                            </MudSelect>
                        </MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => RemoveEntry(context))" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter, EditorRequired] public NotebookAccessDialogModel Model { get; set; } = null!;

    public sealed class NotebookAccessDialogModel
    {
        public Guid NotebookId { get; init; }
        public string NotebookName { get; init; } = "";
        public List<NotebookAccessEntryInfo> Entries { get; init; } = new();
    }

    private readonly List<NotebookAccessEntryInfo> _entries = new();
    private string _newLogin = "";
    private NotebookAccessRoleInfo _newRole = NotebookAccessRoleInfo.Viewer;

    protected override void OnParametersSet()
    {
        _entries.Clear();
        if (Model?.Entries != null)
            _entries.AddRange(Model.Entries.Select(x => new NotebookAccessEntryInfo { UserLogin = x.UserLogin, Role = x.Role }));
    }

    private void AddEntry()
    {
        var login = (_newLogin ?? "").Trim();
        if (string.IsNullOrWhiteSpace(login))
            return;
        if (_entries.Any(x => string.Equals(x.UserLogin, login, StringComparison.OrdinalIgnoreCase)))
            return;
        _entries.Add(new NotebookAccessEntryInfo { UserLogin = login, Role = _newRole });
        _newLogin = "";
        _newRole = NotebookAccessRoleInfo.Viewer;
    }

    private void RemoveEntry(NotebookAccessEntryInfo entry) => _entries.Remove(entry);

    private void UpdateRole(NotebookAccessEntryInfo entry, NotebookAccessRoleInfo role) => entry.Role = role;

    private void Cancel() => MudDialog.Cancel();

    private void Save() => MudDialog.Close(DialogResult.Ok(_entries));
}

