@using System.Collections.Generic
@using System.Linq
@using System.Threading
@using DAP.SqlNotebook.Contract.Entities
@using DAP.SqlNotebook.Service.Client.V1
@using DAP.SqlNotebook.UI.Helpers
@using DAP.SqlNotebook.UI.Services
@using Microsoft.AspNetCore.Components
@using MudBlazor

<div class="workspaces-tree pa-2">
    @* Section: Favorites *@
    <div class="workspaces-tree-row workspaces-tree-section"
         style="padding-left: 4px; cursor: pointer;"
         @onclick="@(() => _favoritesSectionExpanded = !_favoritesSectionExpanded)">
        <span class="material-icons workspaces-tree-icon" aria-hidden="true">@(_favoritesSectionExpanded ? "expand_more" : "chevron_right")</span>
        <span class="material-icons workspaces-tree-icon" style="color: var(--mud-palette-warning);" aria-hidden="true">star</span>
        <span class="workspaces-tree-name" style="font-weight: 600;">Favorites</span>
    </div>
    @if (_favoritesSectionExpanded)
    {
        @if (_loading && _favoriteWorkspaces.Count == 0)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Style="height: 2px; margin-left: 28px;" />
        }
        @foreach (var ws in _favoriteWorkspaces)
        {
            <WorkspaceTreeNode Node="@ws"
                              AllNodes="@_treeNodes"
                              Expanded="@_expanded"
                              PaddingLeft="24"
                              ToggleExpand="@OnToggleExpand"
                              NotebooksByWorkspace="@_notebooksByWorkspace"
                              LoadingNotebooks="@_loadingNotebooks"
                              FavoriteIds="@_favoriteIds"
                              ToggleFavorite="@OnToggleFavorite" />
        }
        @if (!_loading && _favoriteWorkspaces.Count == 0)
        {
            <div class="workspaces-tree-row" style="padding-left: 28px; color: var(--mud-palette-text-secondary); font-size: 0.875rem;">No favorites. Click the star on a workspace to add it.</div>
        }
    }

    @* Section: My workspaces *@
    <div class="workspaces-tree-row workspaces-tree-section"
         style="padding-left: 4px; cursor: pointer;"
         @onclick="@(() => _mySectionExpanded = !_mySectionExpanded)">
        <span class="material-icons workspaces-tree-icon" aria-hidden="true">@(_mySectionExpanded ? "expand_more" : "chevron_right")</span>
        <span class="material-icons workspaces-tree-icon" style="color: var(--mud-palette-primary);" aria-hidden="true">person</span>
        <span class="workspaces-tree-name" style="font-weight: 600;">My workspaces</span>
    </div>
    @if (_mySectionExpanded)
    {
        @if (_loading && _myNodes.Count == 0)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Style="height: 2px; margin-left: 28px;" />
        }
        @foreach (var ws in _myWorkspacesOnly)
        {
            <WorkspaceTreeNode Node="@ws"
                              AllNodes="@_myNodes"
                              Expanded="@_expanded"
                              PaddingLeft="24"
                              ToggleExpand="@OnToggleExpand"
                              NotebooksByWorkspace="@_notebooksByWorkspace"
                              LoadingNotebooks="@_loadingNotebooks"
                              FavoriteIds="@_favoriteIds"
                              ToggleFavorite="@OnToggleFavorite" />
        }
        @if (!_loading && _myWorkspacesOnly.Count == 0)
        {
            <div class="workspaces-tree-row" style="padding-left: 28px; color: var(--mud-palette-text-secondary); font-size: 0.875rem;">No workspaces. Create one from Workspaces page.</div>
        }
    }

    @* Section: Workspaces (common tree) *@
    <div class="workspaces-tree-row workspaces-tree-section"
         style="padding-left: 4px; margin-top: 8px; cursor: pointer;"
         @onclick="@(() => _allSectionExpanded = !_allSectionExpanded)">
        <span class="material-icons workspaces-tree-icon" aria-hidden="true">@(_allSectionExpanded ? "expand_more" : "chevron_right")</span>
        <span class="material-icons workspaces-tree-icon" style="color: var(--mud-palette-primary);" aria-hidden="true">workspaces</span>
        <span class="workspaces-tree-name" style="font-weight: 600;">Workspaces</span>
    </div>
    @if (_allSectionExpanded)
    {
        @if (_loading && _treeNodes.Count == 0)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Style="height: 2px; margin-left: 28px;" />
        }
        @foreach (var root in _rootNodes)
        {
            <WorkspaceTreeNode Node="@root"
                              AllNodes="@_treeNodes"
                              Expanded="@_expanded"
                              PaddingLeft="24"
                              ToggleExpand="@OnToggleExpand"
                              NotebooksByWorkspace="@_notebooksByWorkspace"
                              LoadingNotebooks="@_loadingNotebooks"
                              FavoriteIds="@_favoriteIds"
                              ToggleFavorite="@OnToggleFavorite" />
        }
        @if (!_loading && _treeNodes.Count == 0)
        {
            <div class="workspaces-tree-row" style="padding-left: 28px; color: var(--mud-palette-text-secondary); font-size: 0.875rem;">No workspaces.</div>
        }
    }
</div>

@code {
    [Inject] private IWorkspaceManager WorkspaceManager { get; set; } = null!;
    [Inject] private INotebookManager NotebookManager { get; set; } = null!;
    [Inject] private IWorkspaceFavoritesService FavoritesService { get; set; } = null!;

    private List<WorkspaceInfo> _myNodes = new();
    private List<WorkspaceInfo> _treeNodes = new();
    private HashSet<Guid> _favoriteIds = new();
    /// <summary>Workspaces (not folders) that are in favorites, by name.</summary>
    private List<WorkspaceInfo> _favoriteWorkspaces => _allWorkspacesById.Values.Where(x => _favoriteIds.Contains(x.Id)).OrderBy(x => x.Name).ToList();
    /// <summary>My workspaces: flat list (no folders), all shown.</summary>
    private List<WorkspaceInfo> _myWorkspacesOnly => _myNodes.Where(x => !x.IsFolder).OrderBy(x => x.Name).ToList();
    private List<WorkspaceInfo> _rootNodes => _treeNodes.Where(x => x.ParentId == null).OrderBy(x => x.Name).ToList();
    private Dictionary<Guid, WorkspaceInfo> _allWorkspacesById => _treeNodes.Concat(_myNodes).Where(x => !x.IsFolder).GroupBy(x => x.Id).ToDictionary(g => g.Key, g => g.First());
    private readonly HashSet<Guid> _expanded = new();
    private readonly Dictionary<Guid, List<NotebookMetaInfo>> _notebooksByWorkspace = new();
    private Guid? _loadingNotebooks;
    private bool _loading = true;
    private bool _favoritesSectionExpanded = true;
    private bool _mySectionExpanded = true;
    private bool _allSectionExpanded = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadAll();
    }

    private async Task LoadAll()
    {
        _loading = true;
        try
        {
            var myTask = WorkspaceManager.GetWorkspaces(CancellationToken.None);
            var treeTask = WorkspaceManager.GetTreeAsync(CancellationToken.None);
            var favoritesTask = FavoritesService.GetFavoriteIdsAsync();
            await Task.WhenAll(myTask, treeTask, favoritesTask);
            _myNodes = (await myTask).ToList();
            _treeNodes = (await treeTask).ToList();
            _favoriteIds = await favoritesTask;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnToggleFavorite(Guid workspaceId)
    {
        await FavoritesService.ToggleFavoriteAsync(workspaceId);
        _favoriteIds = await FavoritesService.GetFavoriteIdsAsync();
        StateHasChanged();
    }

    private async Task OnToggleExpand(Guid id)
    {
        if (_expanded.Contains(id))
        {
            _expanded.Remove(id);
        }
        else
        {
            _expanded.Add(id);
            var node = _treeNodes.FirstOrDefault(x => x.Id == id) ?? _myNodes.FirstOrDefault(x => x.Id == id);
            if (node != null && !node.IsFolder && !_notebooksByWorkspace.ContainsKey(id))
            {
                await LoadNotebooksForWorkspace(id);
            }
        }
        StateHasChanged();
    }

    private async Task LoadNotebooksForWorkspace(Guid workspaceId)
    {
        _loadingNotebooks = workspaceId;
        StateHasChanged();
        try
        {
            var response = await NotebookManager.GetNotebooks(CancellationToken.None, queryFilter: null, offset: 0, batchSize: 500, workspaceId: workspaceId);
            _notebooksByWorkspace[workspaceId] = response.Notebooks?.ToList() ?? new List<NotebookMetaInfo>();
        }
        finally
        {
            _loadingNotebooks = null;
            StateHasChanged();
        }
    }
}
