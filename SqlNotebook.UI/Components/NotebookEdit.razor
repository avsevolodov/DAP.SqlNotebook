@namespace DAP.SqlNotebook.UI.Components
@using System.Collections.Generic
@using System.Linq
@using System.Threading
@using DAP.Markdown
@using DAP.SqlNotebook.Contract.Entities
@using DAP.SqlNotebook.UI.Helpers
@using global::SqlNotebook.Mermaid.Components
@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop
@using MudBlazor
@implements IDisposable

<div class="notebook-edit">
    @* Cells list *@
    @if (Notebook?.Cells != null && Notebook.Cells.Count > 0)
    {
        var _cellsList = Notebook.Cells.ToList();
        <MudStack Spacing="2" Class="mb-4">
            @for (var idx = 0; idx < _cellsList.Count; idx++)
            {
                var cell = _cellsList[idx];
                var cellIndex = idx;
                <div id="@($"notebook-cell-{cellIndex}")" class="notebook-cell-wrapper">
                    <div class="d-flex align-items-stretch" style="gap: 8px;">
                        <div class="flex-grow-1">
                            @if (cell.Type == NotebookCellTypeInfo.Markdown)
                            {
                                <NotebookMarkdownCell Cell="cell"
                                                      OnDeleteCell="OnDeleteCell"
                                                      OnCopyCell="@(() => CopyCell(cellIndex))"
                                                      OnMoveUp="@(() => MoveCellUp(cellIndex))"
                                                      OnMoveDown="@(() => MoveCellDown(cellIndex))"
                                                      CanMoveUp="@(cellIndex > 0)"
                                                      CanMoveDown="@(cellIndex < _cellsList.Count - 1)"
                                                      OnCellUpdated="OnCellUpdated" />
                            }
                            else if (cell.Type == NotebookCellTypeInfo.Sql)
                            {
                                <NotebookCodeCell Cell="cell"
                                                  NotebookId="@NotebookId"
                                                  QueryTimeoutSeconds="@QueryTimeoutSeconds"
                                                  SelectTopCount="@SelectTopCount"
                                                  SelectedDatabase="@SelectedDatabase"
                                                  OnChartTypeChanged="OnChartTypeChanged"
                                                  OnFormatCell="OnFormatCell"
                                                  OnDeleteCell="OnDeleteCell"
                                                  OnInsertIntoEditor="OnInsertIntoEditor"
                                                  OnCellUpdated="OnCellUpdated"
                                                  OnCopyCell="@(() => CopyCell(cellIndex))"
                                                  OnMoveUp="@(() => MoveCellUp(cellIndex))"
                                                  OnMoveDown="@(() => MoveCellDown(cellIndex))"
                                                  CanMoveUp="@(cellIndex > 0)"
                                                  CanMoveDown="@(cellIndex < _cellsList.Count - 1)"
                                                  IsExternalRunning="@(IsRunAllBusy && RunAllCurrentCellIndex == cellIndex)" />
                            }
                            else if (cell.Type == NotebookCellTypeInfo.Excalidraw)
                            {
                                <NotebookExcalidrawCell Cell="cell"
                                                        OnDeleteCell="OnDeleteCell"
                                                        OnExcalidrawContentChanged="OnExcalidrawContentChanged"
                                                        OnSaveRequested="OnExcalidrawSaveRequested"
                                                        OnCopyCell="@(() => CopyCell(cellIndex))"
                                                        OnMoveUp="@(() => MoveCellUp(cellIndex))"
                                                        OnMoveDown="@(() => MoveCellDown(cellIndex))"
                                                        CanMoveUp="@(cellIndex > 0)"
                                                        CanMoveDown="@(cellIndex < _cellsList.Count - 1)"
                                                        OnCellUpdated="OnCellUpdated" />
                            }
                            else if (cell.Type == NotebookCellTypeInfo.Mermaid)
                            {
                                <NotebookMermaidCell Cell="cell"
                                                     OnDeleteCell="OnDeleteCell"
                                                     OnContentChanged="OnMermaidContentChanged"
                                                     OnCopyCell="@(() => CopyCell(cellIndex))"
                                                     OnMoveUp="@(() => MoveCellUp(cellIndex))"
                                                     OnMoveDown="@(() => MoveCellDown(cellIndex))"
                                                     CanMoveUp="@(cellIndex > 0)"
                                                     CanMoveDown="@(cellIndex < _cellsList.Count - 1)"
                                                     OnCellUpdated="OnCellUpdated" />
                            }
                        </div>
                    </div>
                </div>
            }
        </MudStack>
    }

    @* Toolbar + Editor *@
    <MudPaper Class="pa-3" Elevation="1" Outlined="true">
        <MudStack Spacing="2">
            <MudStack Row="true"
                      AlignItems="AlignItems.Center"
                      Spacing="2"
                      Wrap="Wrap.Wrap"
                      Justify="Justify.SpaceBetween">
                @* Editor type buttons (left) *@
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Wrap="Wrap.Wrap">
                    <MudButton Variant="@(_activeEditor == EditorMode.Sql ? Variant.Filled : Variant.Outlined)"
                               Color="Color.Primary"
                               OnClick="@(() => SetEditorMode(EditorMode.Sql))"
                               StartIcon="@Icons.Material.Filled.Code">
                        SQL
                    </MudButton>
                    <MudButton Variant="@(_activeEditor == EditorMode.Markdown ? Variant.Filled : Variant.Outlined)"
                               Color="Color.Primary"
                               OnClick="@(() => SetEditorMode(EditorMode.Markdown))"
                               StartIcon="@Icons.Material.Filled.TextFields">
                        Markdown
                    </MudButton>
                    <MudButton Variant="@(_activeEditor == EditorMode.Diagram ? Variant.Filled : Variant.Outlined)"
                               Color="Color.Primary"
                               OnClick="@(() => SetEditorMode(EditorMode.Diagram))"
                               StartIcon="@Icons.Material.Filled.AccountTree">
                        Diagram
                    </MudButton>
                    <MudButton Variant="@(_activeEditor == EditorMode.Excalidraw ? Variant.Filled : Variant.Outlined)"
                               Color="Color.Primary"
                               OnClick="@(() => SetEditorMode(EditorMode.Excalidraw))"
                               StartIcon="@Icons.Material.Filled.Gesture">
                        Excalidraw
                    </MudButton>
                </MudStack>

                @* Per-editor toolbar (right) *@
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Wrap="Wrap.Wrap">
                    @if (_activeEditor == EditorMode.Sql)
                    {
                        @if (IsQueryRunning)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Style="width:24px; height:24px;" />
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Running…</MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.Stop"
                                           Color="Color.Secondary"
                                           Title="Cancel"
                                           OnClick="HandleCancelRun" />
                        }
                        else
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.PlayArrow"
                                           Color="Color.Primary"
                                           Title="Run query"
                                           OnClick="HandleRun" />

                            @* Run as specific chart types *@
                            <MudIconButton Icon="@Icons.Material.Filled.ShowChart"
                                           Color="@(IsCurrentResultChartSelected("line") ? Color.Primary : Color.Default)"
                                           Title="Run as line chart"
                                           OnClick="HandleRunAsLineChart" />
                            <MudIconButton Icon="@Icons.Material.Filled.BarChart"
                                           Color="@(IsCurrentResultChartSelected("bar") ? Color.Primary : Color.Default)"
                                           Title="Run as bar chart"
                                           OnClick="HandleRunAsBarChart" />
                            <MudIconButton Icon="@Icons.Material.Filled.PieChart"
                                           Color="@(IsCurrentResultChartSelected("pie") ? Color.Primary : Color.Default)"
                                           Title="Run as pie chart"
                                           OnClick="HandleRunAsPieChart" />

                            <MudIconButton Icon="@Icons.Material.Filled.FormatAlignLeft"
                                           Title="Format SQL"
                                           OnClick="HandleFormatSql" />
                            <MudIconButton Icon="@Icons.Material.Filled.Save"
                                           Color="Color.Primary"
                                           Title="Save cell"
                                           OnClick="@(() => HandleAddCell(NotebookCellTypeInfo.Sql))" />
                        }

                        <MudIconButton Icon="@Icons.Material.Filled.Clear"
                                       Color="Color.Error"
                                       Title="Clear editor"
                                       OnClick="HandleClearEditor" />
                    }
                    else if (_activeEditor == EditorMode.Markdown)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Save"
                                       Color="Color.Primary"
                                       Title="Save cell"
                                       OnClick="@(() => HandleAddCell(NotebookCellTypeInfo.Markdown))" />

                        <MudIconButton Icon="@Icons.Material.Filled.Clear"
                                       Color="Color.Error"
                                       Title="Clear editor"
                                       OnClick="HandleClearEditor" />
                    }
                    else if (_activeEditor == EditorMode.Diagram)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Save"
                                       Color="Color.Primary"
                                       Title="Save cell"
                                       OnClick="@(() => HandleAddCell(NotebookCellTypeInfo.Mermaid))" />

                        <MudIconButton Icon="@Icons.Material.Filled.Clear"
                                       Color="Color.Error"
                                       Title="Clear editor"
                                       OnClick="HandleClearEditor" />
                    }
                    else if (_activeEditor == EditorMode.Excalidraw)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Save"
                                       Color="Color.Primary"
                                       Title="Save cell"
                                       OnClick="@(() => HandleAddCell(NotebookCellTypeInfo.Excalidraw))" />

                        <MudIconButton Icon="@Icons.Material.Filled.Clear"
                                       Color="Color.Error"
                                       Title="Clear editor"
                                       OnClick="HandleClearEditor" />
                    }

                    <MudMenu Open="_settingsOpen" OpenChanged="e => _settingsOpen = e" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                        <ActivatorContent>
                            <MudIconButton Icon="@Icons.Material.Filled.Settings" Title="Editor settings" OnClick="@(() => _settingsOpen = true)" />
                        </ActivatorContent>
                        <ChildContent>
                            <MudPaper Class="pa-3" Style="min-width: 200px;">
                                <MudText Typo="Typo.subtitle2" Class="mb-2">Editor settings</MudText>
                                <MudSelect T="string" Label="Theme" Value="@_editorTheme" ValueChanged="OnEditorThemeChanged" Variant="Variant.Outlined" Dense="true" Class="mt-2">
                                    <MudSelectItem Value="@("vs-dark")">Dark</MudSelectItem>
                                    <MudSelectItem Value="@("vs")">Light</MudSelectItem>
                                    <MudSelectItem Value="@("hc-black")">High contrast</MudSelectItem>
                                </MudSelect>
                                <MudNumericField T="int?" Value="_timeoutLocal" ValueChanged="OnTimeoutChanged" Label="Timeout (s)" Min="1" Max="300" Variant="Variant.Outlined" Dense="true" Class="mt-2" Style="max-width: 100%;" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Timer" Disabled="@IsQueryRunning" />
                                <MudNumericField T="int" Value="_selectTopLocal" ValueChanged="OnSelectTopChanged" Label="TOP (rows)" Min="1" Max="10000" Variant="Variant.Outlined" Dense="true" Class="mt-2" Style="max-width: 100%;" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.TableChart" Disabled="@IsQueryRunning" />
                            </MudPaper>
                        </ChildContent>
                    </MudMenu>
                </MudStack>
            </MudStack>
            @if (!string.IsNullOrWhiteSpace(ExecutionError))
            {
                <MudAlert Severity="Severity.Error" Class="mt-2" Dismissible="true" OnClose="ClearExecutionError">
                    @(ExecutionError)
                </MudAlert>
            }
            @if (_activeEditor == EditorMode.Sql)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">New SQL cell</MudText>
                <div id="@_editorElementId" class="sql-notebook-editor-container"></div>
                @if (CurrentRunResult != null)
                {
                    <div class="notebook-current-result mt-3">
                        @if (CurrentRunResult.Columns != null && CurrentRunResult.Columns.Length > 0)
                        {
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                                <MudIconButton Icon="@Icons.Material.Filled.TableChart"
                                               Size="Size.Small"
                                               Color="@(IsCurrentResultChartSelected("table") ? Color.Primary : Color.Default)"
                                               Title="Table view"
                                               OnClick="SetCurrentResultChartTypeTable" />
                                <MudIconButton Icon="@Icons.Material.Filled.ShowChart"
                                               Size="Size.Small"
                                               Color="@(IsCurrentResultChartSelected("line") ? Color.Primary : Color.Default)"
                                               Title="Line chart"
                                           Disabled="@(!_canShowLineChart)"
                                               OnClick="SetCurrentResultChartTypeLine" />
                                <MudIconButton Icon="@Icons.Material.Filled.BarChart"
                                               Size="Size.Small"
                                               Color="@(IsCurrentResultChartSelected("bar") ? Color.Primary : Color.Default)"
                                               Title="Bar chart"
                                           Disabled="@(!_canShowBarChart)"
                                               OnClick="SetCurrentResultChartTypeBar" />
                                <MudIconButton Icon="@Icons.Material.Filled.PieChart"
                                               Size="Size.Small"
                                               Color="@(IsCurrentResultChartSelected("pie") ? Color.Primary : Color.Default)"
                                               Title="Pie chart"
                                           Disabled="@(!_canShowPieChart)"
                                               OnClick="SetCurrentResultChartTypePie" />
                                <MudIconButton Icon="@Icons.Material.Filled.Download"
                                               Size="Size.Small"
                                               Title="Download CSV (full result)"
                                               OnClick="DownloadCurrentResultCsv" />
                            </MudStack>
                        }
                        <NotebookQueryResult Result="@CurrentRunResult"
                                             MaxHeight="300"
                                             ForceTable="@(_currentResultView == ResultViewMode.Table)"
                                             EffectiveChartType="@_currentResultChartType" />
                    </div>
                }
            }
            else if (_activeEditor == EditorMode.Markdown)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">New Markdown cell</MudText>
                <MudGrid GutterSize="GutterSize.Small">
                    <MudItem xs="12" md="6">
                        <MudTextField Lines="10"
                                      Value="@(SqlEditorContent ?? string.Empty)"
                                      ValueChanged="SqlEditorContentChanged"
                                      Immediate="true"
                                      Label="Markdown content"
                                      Variant="Variant.Outlined"
                                      FullWidth="true"
                                      Textarea="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Preview</MudText>
                        <MudPaper Class="pa-2" Elevation="0">
                            <MudMarkdown Value="@(SqlEditorContent ?? string.Empty)" Props="GetMarkdownProps()" />
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            }
            else if (_activeEditor == EditorMode.Diagram)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">New Diagram cell (Mermaid)</MudText>
                <MudGrid GutterSize="GutterSize.Small">
                    <MudItem xs="12" md="6">
                        <MudTextField Lines="10"
                                      Value="@(SqlEditorContent ?? string.Empty)"
                                      ValueChanged="SqlEditorContentChanged"
                                      Immediate="true"
                                      Label="Mermaid diagram definition"
                                      Variant="Variant.Outlined"
                                      FullWidth="true"
                                      Textarea="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Preview</MudText>
                        @if (!string.IsNullOrWhiteSpace(SqlEditorContent))
                        {
                            <MudPaper Class="pa-2" Elevation="0" Style="max-height: 300px; overflow:auto;">
                                <MermaidDiagram Text="@(SqlEditorContent ?? string.Empty)" CssClass="mermaid-cell-diagram" />
                            </MudPaper>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Enter Mermaid code to see preview.</MudText>
                        }
                    </MudItem>
                </MudGrid>
            }
            else if (_activeEditor == EditorMode.Excalidraw)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">New Excalidraw cell</MudText>
                <div class="notebook-excalidraw-wrap" style="height: 400px; min-height: 300px;">
                    <iframe id="@_excalidrawEditorIframeId"
                            src="excalidraw/embed.html"
                            title="Excalidraw editor"
                            style="width: 100%; height: 100%; border: 1px solid var(--mud-palette-lines-default); border-radius: 4px; pointer-events: auto;"
                            @onload="HandleExcalidrawEditorLoad" />
                </div>
            }

            @* Bottom "Add cell" button for the editor *@
            <MudStack Row="true" Spacing="1" Class="mt-3" AlignItems="AlignItems.Center">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="HandleAddCurrentEditorCell">
                    Add cell
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>
</div>

@code {
    [Parameter, EditorRequired] public NotebookInfo Notebook { get; set; } = null!;
    [Parameter] public Guid NotebookId { get; set; }
    [Parameter] public CatalogNodeInfo? SelectedDatabase { get; set; }
    [Parameter] public string? SqlEditorContent { get; set; }
    [Parameter] public EventCallback<string?> SqlEditorContentChanged { get; set; }
    [Parameter] public NotebookCellExecutionResultInfo? CurrentRunResult { get; set; }
    [Parameter] public int? QueryTimeoutSeconds { get; set; }
    [Parameter] public EventCallback<int?> OnQueryTimeoutChanged { get; set; }
    [Parameter] public int SelectTopCount { get; set; } = 10;
    [Parameter] public EventCallback<int> OnSelectTopCountChanged { get; set; }
    [Parameter] public bool IsQueryRunning { get; set; }
    [Parameter] public EventCallback OnCancelRun { get; set; }
    [Parameter] public EventCallback OnRun { get; set; }
    [Parameter] public EventCallback<string> OnRunSqlFromMarkdown { get; set; }
    [Parameter] public EventCallback<string> OnRunAsChart { get; set; }
    [Parameter] public EventCallback<NotebookCellTypeInfo> OnAddCell { get; set; }
    [Parameter] public EventCallback<string> OnInsertIntoEditor { get; set; }
    [Parameter] public string? ExecutionError { get; set; }
    [Parameter] public EventCallback<string?> ExecutionErrorChanged { get; set; }
    [Parameter] public EventCallback<(int CellId, string ChartType)> OnChartTypeChanged { get; set; }
    [Parameter] public EventCallback<(int CellId, string FormattedContent)> OnFormatCell { get; set; }
    [Parameter] public EventCallback<(int CellId, string Content)> OnExcalidrawContentChanged { get; set; }
    [Parameter] public EventCallback<int> OnExcalidrawSaveRequested { get; set; }
    [Parameter] public EventCallback<string?> OnExcalidrawEditorContentChanged { get; set; }
    [Parameter] public EventCallback<(int CellId, string Content)> OnMermaidContentChanged { get; set; }
    [Parameter] public EventCallback<NotebookCellInfo> OnDeleteCell { get; set; }
    [Parameter] public EventCallback OnCellUpdated { get; set; }
    [Parameter] public int? RunAllCurrentCellIndex { get; set; }
    [Parameter] public bool IsRunAllBusy { get; set; }

    [Inject] private IJSRuntime JS { get; set; } = null!;
    [Inject] private ICatalogInsertService CatalogInsertService { get; set; } = null!;

    private const string EditorElementId = "sql-notebook-editor";
    private string _editorElementId = EditorElementId;
    private string? _lastSetContent;
    private int? _timeoutLocal;
    private int _selectTopLocal = 10;
    private bool _editorCreated;
    private DotNetObjectReference<NotebookEdit>? _dotNetRef;
    private int _createRetryCount;
    private const int MaxCreateRetries = 25;
    private bool _settingsOpen;
    private string _editorTheme = "vs-dark";
    private int _lastCellCount = -1;
    private MudMarkdownProps? _cachedMarkdownProps;
    private string? _currentResultChartType;
    private bool _canShowLineChart;
    private bool _canShowBarChart;
    private bool _canShowPieChart;

    private enum ResultViewMode
    {
        Table,
        Charts
    }

    private ResultViewMode _currentResultView = ResultViewMode.Table;

    private enum EditorMode { Sql, Markdown, Diagram, Excalidraw }
    private EditorMode _activeEditor = EditorMode.Sql;
    private string _excalidrawEditorIframeId = "excalidraw-editor";

    protected override void OnParametersSet()
    {
        if (QueryTimeoutSeconds != _timeoutLocal)
            _timeoutLocal = QueryTimeoutSeconds;
        if (SelectTopCount != _selectTopLocal && SelectTopCount >= 1)
        {
            _selectTopLocal = SelectTopCount;
            CatalogInsertService.SelectTopCount = SelectTopCount;
        }

        // Sync current result view & chart type with incoming result
        if (CurrentRunResult != null)
        {
            var ct = (CurrentRunResult.ChartType ?? string.Empty).Trim().ToLowerInvariant();
            _currentResultChartType = string.IsNullOrEmpty(ct) ? null : ct;
            _currentResultView = string.IsNullOrEmpty(ct) || ct == "table"
                ? ResultViewMode.Table
                : ResultViewMode.Charts;
        }

        UpdateChartCapabilities();
    }

    private async Task MoveCellUp(int index)
    {
        if (Notebook?.Cells == null || index <= 0 || index >= Notebook.Cells.Count)
            return;
        var list = Notebook.Cells.ToList();
        var item = list[index];
        list.RemoveAt(index);
        list.Insert(index - 1, item);
        Notebook.Cells = list;
        if (OnCellUpdated.HasDelegate)
            await OnCellUpdated.InvokeAsync();
    }

    private async Task CopyCell(int index)
    {
        if (Notebook?.Cells == null || index < 0 || index >= Notebook.Cells.Count)
            return;

        var list = Notebook.Cells.ToList();
        var original = list[index];

        var copy = new NotebookCellInfo
        {
            Id = 0,
            Type = original.Type,
            Content = original.Content ?? string.Empty,
            ExecutionResult = original.ExecutionResult ?? new NotebookCellExecutionResultInfo(),
            CreatedBy = original.CreatedBy,
            Title = original.Title,
            CatalogNodeId = original.CatalogNodeId,
            DatabaseDisplayName = original.DatabaseDisplayName
        };

        list.Insert(index + 1, copy);
        Notebook.Cells = list;

        if (OnCellUpdated.HasDelegate)
            await OnCellUpdated.InvokeAsync();
    }

    private async Task MoveCellDown(int index)
    {
        if (Notebook?.Cells == null || index < 0 || index >= Notebook.Cells.Count - 1)
            return;
        var list = Notebook.Cells.ToList();
        var item = list[index];
        list.RemoveAt(index);
        list.Insert(index + 1, item);
        Notebook.Cells = list;
        if (OnCellUpdated.HasDelegate)
            await OnCellUpdated.InvokeAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            _dotNetRef = DotNetObjectReference.Create(this);

        var content = SqlEditorContent ?? "";
        if (!_editorCreated)
        {
            try
            {
                var created = await JS.InvokeAsync<bool>("sqlNotebookMonaco.createAsync", _editorElementId, "sql", content);
                if (created)
                {
                    _editorCreated = true;
                    _lastSetContent = content;
                    _lastCellCount = Notebook?.Cells?.Count ?? 0;
                    if (_dotNetRef != null)
                        await JS.InvokeVoidAsync("sqlNotebookMonaco.registerRunCommand", _editorElementId, _dotNetRef);
                    try { await JS.InvokeVoidAsync("sqlNotebookMonaco.ensureEditorEditable", _editorElementId); } catch { }
                    CatalogInsertService.SetInsertAtCursorCallback(InsertColumnNameAtCursorAsync);
                    CatalogInsertService.SetPasteToEditorCallback(PasteToEditorToMonacoAsync);
                    try
                    {
                        _editorTheme = await JS.InvokeAsync<string>("sqlNotebookMonaco.getEditorTheme") ?? "vs-dark";
                    }
                    catch { }
                    try { await JS.InvokeVoidAsync("sqlNotebookHighlightCode"); } catch { }
                }
                else
                {
                    // Element not in DOM yet (e.g. after client-side navigation); retry after short delay
                    _createRetryCount++;
                    if (_createRetryCount < MaxCreateRetries)
                    {
                        await Task.Delay(100);
                        await InvokeAsync(StateHasChanged);
                    }
                }
            }
            catch (Exception)
            {
                _createRetryCount++;
                if (_createRetryCount < MaxCreateRetries)
                {
                    await Task.Delay(100);
                    await InvokeAsync(StateHasChanged);
                }
            }
            return;
        }
        if (_lastSetContent != content)
        {
            try
            {
                await JS.InvokeVoidAsync("sqlNotebookMonaco.setValue", _editorElementId, content);
                _lastSetContent = content;
                await JS.InvokeVoidAsync("sqlNotebookHighlightCode");
            }
            catch { }
        }
        else
        {
            var cellCount = Notebook?.Cells?.Count ?? 0;
            if (cellCount != _lastCellCount)
            {
                _lastCellCount = cellCount;
                try
                {
                    await JS.InvokeVoidAsync("sqlNotebookHighlightCode");
                    await JS.InvokeVoidAsync("sqlNotebookMonaco.ensureEditorEditable", _editorElementId);
                }
                catch { }
            }
        }
    }

    [JSInvokable]
    public async Task RunFromEditor()
    {
        await HandleRun();
    }

    [JSInvokable]
    public async Task OnExcalidrawEditorChange(string content)
    {
        if (OnExcalidrawEditorContentChanged.HasDelegate)
        {
            await OnExcalidrawEditorContentChanged.InvokeAsync(content);
        }
    }

    [JSInvokable]
    public async Task OnExcalidrawEditorReady()
    {
        // If needed, we can send previously saved state back to the editor.
        await Task.CompletedTask;
    }

    private async Task HandleRun()
    {
        await FlushEditorContent();
        await OnRun.InvokeAsync();
    }

    private void SetEditorMode(EditorMode mode)
    {
        _activeEditor = mode;
    }

    private async Task HandleRunAsChart(string chartType)
    {
        // When running as chart from the editor toolbar, switch result view and chart type
        SetCurrentResultChartType(chartType);

        await FlushEditorContent();
        if (OnRunAsChart.HasDelegate)
        {
            await OnRunAsChart.InvokeAsync(chartType);
        }
    }

    private Task HandleRunAsLineChart() => HandleRunAsChart("line");
    private Task HandleRunAsBarChart() => HandleRunAsChart("bar");
    private Task HandleRunAsPieChart() => HandleRunAsChart("pie");

    private string GetCurrentResultChartType()
    {
        return (_currentResultChartType ?? string.Empty).Trim().ToLowerInvariant();
    }

    private bool IsCurrentResultChartSelected(string chartType)
    {
        var current = GetCurrentResultChartType();
        if (string.IsNullOrEmpty(current) && chartType == "table")
            return _currentResultView == ResultViewMode.Table;
        if (string.IsNullOrEmpty(current) && chartType == "line")
            return _currentResultView == ResultViewMode.Charts;
        return current == chartType;
    }

    private void SetCurrentResultChartType(string chartType)
    {
        var ct = (chartType ?? string.Empty).Trim().ToLowerInvariant();

        if (ct == "table" || string.IsNullOrEmpty(ct))
        {
            _currentResultView = ResultViewMode.Table;
            _currentResultChartType = null;
        }
        else
        {
            _currentResultView = ResultViewMode.Charts;
            _currentResultChartType = ct;
        }
        StateHasChanged();
    }

    private void SetCurrentResultChartTypeTable() => SetCurrentResultChartType("table");
    private void SetCurrentResultChartTypeLine() => SetCurrentResultChartType("line");
    private void SetCurrentResultChartTypeBar() => SetCurrentResultChartType("bar");
    private void SetCurrentResultChartTypePie() => SetCurrentResultChartType("pie");

    private void UpdateChartCapabilities()
    {
        _canShowLineChart = _canShowBarChart = _canShowPieChart = false;
        var result = CurrentRunResult;
        if (result?.Columns == null || result.Columns.Length == 0 || result.Rows == null || result.Rows.Length == 0)
            return;

        var colCount = result.Columns.Length;
        var rows = result.Rows;
        var bestNumericCount = 0;

        for (var c = 0; c < colCount; c++)
        {
            var numericCount = 0;
            foreach (var row in rows)
            {
                var values = row.Values?.ToList() ?? new List<string>();
                var cell = c < values.Count ? values[c] ?? string.Empty : string.Empty;
                if (TryParseDouble(cell, out _))
                    numericCount++;
            }

            if (numericCount > 0)
            {
                _canShowLineChart = true;
                _canShowBarChart = true;
                if (numericCount > bestNumericCount)
                    bestNumericCount = numericCount;
            }
        }

        _canShowPieChart = bestNumericCount > 0;
    }

    private static bool TryParseDouble(string? text, out double value)
    {
        return double.TryParse(
            text?.Trim(),
            System.Globalization.NumberStyles.Float | System.Globalization.NumberStyles.AllowThousands,
            System.Globalization.CultureInfo.InvariantCulture,
            out value);
    }

    private async Task DownloadCurrentResultCsv()
    {
        var query = (SqlEditorContent ?? "").Trim();
        if (string.IsNullOrWhiteSpace(query)) return;
        var path = $"/api/v1/notebooks/{NotebookId}/execute/export-csv";
        var body = new { Query = query, CommandTimeoutSeconds = QueryTimeoutSeconds ?? 30, CatalogNodeId = SelectedDatabase?.Id };
        await JS.InvokeVoidAsync("sqlNotebookDownloadCsv", path, body);
    }

    private async Task HandleAddCell(NotebookCellTypeInfo cellType)
    {
        await FlushEditorContent();
        if (OnAddCell.HasDelegate)
        {
            await OnAddCell.InvokeAsync(cellType);
        }

        if (cellType == NotebookCellTypeInfo.Excalidraw)
        {
            try
            {
                // Clear the main Excalidraw editor content after creating a cell
                await JS.InvokeVoidAsync("sqlNotebookExcalidraw.sendContent", _excalidrawEditorIframeId, "{}");
                if (OnExcalidrawEditorContentChanged.HasDelegate)
                    await OnExcalidrawEditorContentChanged.InvokeAsync(null);
            }
            catch
            {
                // Ignore errors while clearing the editor (e.g. when not visible)
            }
        }
    }

    private async Task HandleFormatSql()
    {
        try
        {
            await JS.InvokeVoidAsync("sqlNotebookMonaco.formatDocument", _editorElementId);
            await FlushEditorContent();
        }
        catch { }
    }

    private async Task HandleCancelRun()
    {
        if (OnCancelRun.HasDelegate)
            await OnCancelRun.InvokeAsync();
    }

    private async Task HandleClearEditor()
    {
        // "Delete" only the editor cell: clear its content, do not touch existing notebook cells.
        if (_activeEditor == EditorMode.Sql)
        {
            try
            {
                await JS.InvokeVoidAsync("sqlNotebookMonaco.setValue", _editorElementId, string.Empty);
            }
            catch
            {
                // ignore JS errors
            }

            _lastSetContent = string.Empty;
            await SqlEditorContentChanged.InvokeAsync(string.Empty);
            return;
        }

        if (_activeEditor == EditorMode.Excalidraw)
        {
            try
            {
                await JS.InvokeVoidAsync("sqlNotebookExcalidraw.sendContent", _excalidrawEditorIframeId, "{}");
                if (OnExcalidrawEditorContentChanged.HasDelegate)
                    await OnExcalidrawEditorContentChanged.InvokeAsync(null);
            }
            catch
            {
                // Ignore errors while clearing the editor (e.g. when not visible)
            }
        }
        else
        {
            _lastSetContent = string.Empty;
            await SqlEditorContentChanged.InvokeAsync(string.Empty);
        }
    }

    private Task HandleAddCurrentEditorCell()
    {
        var cellType = _activeEditor switch
        {
            EditorMode.Sql => NotebookCellTypeInfo.Sql,
            EditorMode.Markdown => NotebookCellTypeInfo.Markdown,
            EditorMode.Diagram => NotebookCellTypeInfo.Mermaid,
            EditorMode.Excalidraw => NotebookCellTypeInfo.Excalidraw,
            _ => NotebookCellTypeInfo.Sql
        };

        return HandleAddCell(cellType);
    }

    private async Task FlushEditorContent()
    {
        try
        {
            var value = await GetEditorContentAsync();
            _lastSetContent = value ?? "";
            await SqlEditorContentChanged.InvokeAsync(value);
            if (OnQueryTimeoutChanged.HasDelegate && _timeoutLocal != QueryTimeoutSeconds)
                await OnQueryTimeoutChanged.InvokeAsync(_timeoutLocal);
        }
        catch { }
    }

    private async Task OnTimeoutChanged(int? value)
    {
        _timeoutLocal = value;
        if (OnQueryTimeoutChanged.HasDelegate)
            await OnQueryTimeoutChanged.InvokeAsync(value);
    }

    private async Task OnSelectTopChanged(int value)
    {
        var n = Math.Clamp(value, 1, 10000);
        _selectTopLocal = n;
        CatalogInsertService.SelectTopCount = n;
        if (OnSelectTopCountChanged.HasDelegate)
            await OnSelectTopCountChanged.InvokeAsync(n);
    }

